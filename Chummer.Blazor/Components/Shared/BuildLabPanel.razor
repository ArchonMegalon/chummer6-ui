@namespace Chummer.Blazor.Components.Shared

@using Chummer.Contracts.Presentation

<section class="panel design-panel" data-build-lab-showcase="@Projection.WorkspaceId">
    <header class="panel-header">
        <div>
            <h2>@Projection.Title</h2>
            <p class="note">@Projection.Summary</p>
        </div>
        <div class="button-row compact">
            <span>@Projection.RulesetId</span>
            <span>@Projection.BuildMethod</span>
        </div>
    </header>

    <div class="build-lab-chip-group">
        @foreach (BuildLabBadge badge in Projection.RoleBadges)
        {
            <span class="browse-chip @(badge.Emphasized ? "active" : null)">@badge.Label</span>
        }
    </div>

    <div class="build-lab-field-grid">
        @foreach (BuildLabIntakeField field in Projection.IntakeFields)
        {
            <label class="field">
                <span>@field.Label</span>
                <input value="@field.Value" readonly placeholder="@field.Placeholder" />
                @if (!string.IsNullOrWhiteSpace(field.HelpText))
                {
                    <span class="note">@field.HelpText</span>
                }
            </label>
        }
    </div>

    <div class="build-lab-chip-group">
        @foreach (BuildLabBadge badge in Projection.ConstraintBadges)
        {
            <span class="browse-chip @(badge.Emphasized ? "active" : null)">@badge.Label</span>
        }
    </div>

    @if (Projection.ProvenanceBadges.Count > 0)
    {
        <div class="build-lab-chip-group">
            @foreach (BuildLabBadge badge in Projection.ProvenanceBadges)
            {
                <span class="browse-chip @(badge.Emphasized ? "active" : null)">@badge.Label</span>
            }
        </div>
    }

    <section class="coach-card">
        <div class="coach-card-header">
            <h3>Explain + Source</h3>
            <span class="badge">Engine DTO</span>
        </div>
        <dl class="facts compact">
            <div><dt>Explain</dt><dd>@(Projection.ExplainEntryId ?? "none")</dd></div>
            <div><dt>Source</dt><dd>@(Projection.SourceDocumentId ?? "none")</dd></div>
            <div><dt>Next</dt><dd>@(Projection.CanContinue ? "Compare variants" : "Complete intake")</dd></div>
        </dl>
    </section>

    @if (!string.IsNullOrWhiteSpace(Projection.NextSafeAction)
        || !string.IsNullOrWhiteSpace(Projection.RuntimeCompatibilitySummary)
        || !string.IsNullOrWhiteSpace(Projection.CampaignFitSummary)
        || !string.IsNullOrWhiteSpace(Projection.SupportClosureSummary)
        || Projection.Watchouts is { Count: > 0 })
    {
        <section class="coach-card" data-build-lab-decision-rail>
            <div class="coach-card-header">
                <h3>Campaign-safe decision rail</h3>
                <span class="badge">Next safe action</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(Projection.NextSafeAction))
            {
                <p><strong>@Projection.NextSafeAction</strong></p>
            }
            <dl class="facts compact">
                @if (!string.IsNullOrWhiteSpace(Projection.RuntimeCompatibilitySummary))
                {
                    <div><dt>Runtime</dt><dd>@Projection.RuntimeCompatibilitySummary</dd></div>
                }
                @if (!string.IsNullOrWhiteSpace(Projection.CampaignFitSummary))
                {
                    <div><dt>Campaign fit</dt><dd>@Projection.CampaignFitSummary</dd></div>
                }
                @if (!string.IsNullOrWhiteSpace(Projection.SupportClosureSummary))
                {
                    <div><dt>Support</dt><dd>@Projection.SupportClosureSummary</dd></div>
                }
            </dl>
            @if (Projection.Watchouts is { Count: > 0 })
            {
                <ul class="browse-detail-lines">
                    @foreach (string watchout in Projection.Watchouts)
                    {
                        <li>@watchout</li>
                    }
                </ul>
            }
        </section>
    }

    @if (HasBuildBlockerReceipt(Projection))
    {
        <section class="coach-card" data-build-blocker-explain-receipt>
            <div class="coach-card-header">
                <h3>Build blocker receipt</h3>
                <span class="badge">@BuildBuildBlockerBadge(Projection)</span>
            </div>
            <dl class="facts compact">
                <div><dt>Explain receipt</dt><dd>@BuildBuildBlockerExplainReceipt(Projection)</dd></div>
                <div><dt>Rule environment</dt><dd>@BuildBuildBlockerEnvironment(Projection)</dd></div>
                <div><dt>Environment diff</dt><dd>@BuildBuildBlockerEnvironmentDiff(Projection)</dd></div>
                <div><dt>Before</dt><dd>@BuildBuildBlockerBefore(Projection)</dd></div>
                <div><dt>After</dt><dd>@BuildBuildBlockerAfter(Projection)</dd></div>
                <div><dt>Support reuse</dt><dd>@BuildBuildBlockerSupport(Projection)</dd></div>
            </dl>
        </section>
    }

    @if (Projection.Variants.Count > 0)
    {
        <section class="coach-card">
            <div class="coach-card-header">
                <h3>Variant Comparison</h3>
                <span class="badge">@Projection.Variants.Count option(s)</span>
            </div>
            @foreach (BuildLabVariantProjection variant in Projection.Variants)
            {
                <article data-build-lab-variant-showcase="@variant.VariantId">
                    <p><strong>@variant.Label</strong> · @variant.TableFit</p>
                    <p class="note">@variant.Summary</p>
                    <p class="note">@string.Join(" | ", variant.Metrics.Select(metric => $"{metric.Label}: {metric.Value}{(string.IsNullOrWhiteSpace(metric.Delta) ? string.Empty : $" ({metric.Delta})")}"))</p>
                    @if (variant.Warnings.Count > 0)
                    {
                        <p class="note">@string.Join(" | ", variant.Warnings.Select(warning => warning.Label))</p>
                    }
                    @if (variant.OverlapBadges.Count > 0)
                    {
                        <p class="note">@string.Join(" | ", variant.OverlapBadges.Select(badge => badge.Label))</p>
                    }
                </article>
            }
        </section>
    }

    @if (Projection.ProgressionTimelines.Count > 0)
    {
        <section class="coach-card">
            <div class="coach-card-header">
                <h3>25 / 50 / 100 Karma</h3>
                <span class="badge">Progression</span>
            </div>
            @foreach (BuildLabProgressionTimeline timeline in Projection.ProgressionTimelines)
            {
                <article data-build-lab-timeline-showcase="@timeline.TimelineId">
                    <p><strong>@timeline.Title</strong> · @timeline.VariantId</p>
                    <p class="note">@timeline.Summary</p>
                    <ul class="browse-detail-lines">
                        @foreach (BuildLabProgressionStep step in timeline.Steps)
                        {
                            <li>
                                <strong>@step.KarmaTarget Karma</strong> · @step.Label · @step.Summary
                                @if (step.Outcomes.Count > 0)
                                {
                                    <span> · @string.Join(" | ", step.Outcomes.Select(metric => $"{metric.Label}: {metric.Value}"))</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(step.ExplainEntryId))
                                {
                                    <span> · Explain: @step.ExplainEntryId</span>
                                }
                                @if (step.MilestoneBadges.Count > 0 || step.RiskBadges.Count > 0)
                                {
                                    <div class="build-lab-chip-group" data-build-lab-timeline-step-badges="@step.StepId">
                                        @foreach (BuildLabBadge badge in step.MilestoneBadges)
                                        {
                                            <span class="browse-chip @(badge.Emphasized ? "active" : null)">@badge.Label</span>
                                        }
                                        @foreach (BuildLabBadge badge in step.RiskBadges)
                                        {
                                            <span class="browse-chip @(badge.Emphasized ? "active" : null)">@badge.Label</span>
                                        }
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                    @if (!string.IsNullOrWhiteSpace(timeline.SourceDocumentId))
                    {
                        <p class="note">Source: @timeline.SourceDocumentId</p>
                    }
                </article>
            }
        </section>
    }

    @if (HasPlannerCoverageSignals(Projection))
    {
        <section class="coach-card" data-build-lab-optimizer-rail>
            <div class="coach-card-header">
                <h3>Planner + team coverage</h3>
                <span class="badge">@BuildPlannerCoverageBadge(Projection)</span>
            </div>
            <p><strong>@BuildPlannerCoverageSummary(Projection)</strong></p>
            <ul class="browse-detail-lines">
                @foreach (string line in BuildPlannerCoverageLines(Projection))
                {
                    <li>@line</li>
                }
            </ul>
        </section>
    }

    @if (Projection is BuildLabConceptIntakeProjection buildLabProjection && buildLabProjection.Actions is { Count: > 0 } buildLabActions)
    {
        <section class="coach-card" data-build-lab-export-showcase>
            <div class="coach-card-header">
                <h3>Export + Hand-off</h3>
                <span class="badge">@buildLabActions.Count action(s)</span>
            </div>

            @if (buildLabProjection.ExportPayloads?.Count > 0)
            {
                @foreach (BuildLabExportPayload payload in buildLabProjection.ExportPayloads)
                {
                    <article data-build-lab-export-payload-showcase="@payload.PayloadId">
                        <p><strong>@payload.Title</strong> · @payload.PayloadKind</p>
                        <p class="note">@payload.Summary</p>
                        <p class="note">@string.Join(" | ", payload.Fields.Select(field => $"{field.Label}: {field.Value}"))</p>
                        @if (!string.IsNullOrWhiteSpace(payload.QueryText))
                        {
                            <p class="note">Query: @payload.QueryText</p>
                        }
                    </article>
                }
            }

            @if (Projection.ExportTargets?.Count > 0)
            {
                @foreach (BuildLabExportTarget target in Projection.ExportTargets)
                {
                    <article data-build-lab-export-target-showcase="@target.TargetId">
                        <p><strong>@target.Label</strong> · @target.TargetKind</p>
                        <p class="note">@target.Description</p>
                    </article>
                }
            }
        </section>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public BuildLabConceptIntakeProjection Projection { get; set; } = new(
        WorkspaceId: "build-lab-showcase",
        WorkflowId: "workflow.build-lab",
        Title: "Build Lab Intake",
        Summary: "Capture concept, role intent, and table constraints before variant generation.",
        RulesetId: "sr5",
        BuildMethod: "Priority",
        IntakeFields:
        [
            new BuildLabIntakeField("concept", "Concept", BuildLabFieldKinds.Text, string.Empty)
        ],
        RoleBadges: [],
        ConstraintBadges: [],
        ProvenanceBadges: [],
        Variants: [],
        ProgressionTimelines: [],
        ExportPayloads: [],
        ExportTargets: [],
        Actions: []);

    private static bool HasPlannerCoverageSignals(BuildLabConceptIntakeProjection projection)
    {
        if (projection.TeamCoverage is not null)
        {
            return true;
        }

        if (projection.ProgressionTimelines.Count > 0)
        {
            return true;
        }

        foreach (BuildLabVariantProjection variant in projection.Variants)
        {
            if (HasCoverageSignals(variant))
            {
                return true;
            }
        }

        return false;
    }

    private static string BuildPlannerCoverageBadge(BuildLabConceptIntakeProjection projection)
    {
        if (projection.TeamCoverage is { } teamCoverage)
        {
            return $"{teamCoverage.CoveredRoleTags?.Count ?? 0} covered · {teamCoverage.MissingRoleTags.Count} missing · {teamCoverage.DuplicateRoleTags?.Count ?? 0} duplicate";
        }

        int optimizerReadyVariants = 0;
        foreach (BuildLabVariantProjection variant in projection.Variants)
        {
            if (HasCoverageSignals(variant))
            {
                optimizerReadyVariants++;
            }
        }

        int checkpoints = 0;
        foreach (BuildLabProgressionTimeline timeline in projection.ProgressionTimelines)
        {
            checkpoints += timeline.Steps.Count;
        }

        return $"{optimizerReadyVariants} variant(s) · {checkpoints} checkpoint(s)";
    }

    private static string BuildPlannerCoverageSummary(BuildLabConceptIntakeProjection projection)
    {
        if (projection.TeamCoverage is { } teamCoverage)
        {
            return teamCoverage.Summary;
        }

        int optimizerReadyVariants = 0;
        foreach (BuildLabVariantProjection variant in projection.Variants)
        {
            if (HasCoverageSignals(variant))
            {
                optimizerReadyVariants++;
            }
        }

        return $"{optimizerReadyVariants} optimizer-ready variant(s) across {projection.ProgressionTimelines.Count} progression timeline(s).";
    }

    private static IReadOnlyList<string> BuildPlannerCoverageLines(BuildLabConceptIntakeProjection projection)
    {
        List<string> lines = [];
        lines.AddRange(BuildTeamCoverageLines(projection.TeamCoverage));

        foreach (BuildLabVariantProjection variant in projection.Variants)
        {
            List<string> signals = [];
            string coverageMetrics = string.Join(
                " | ",
                variant.Metrics
                    .Where(IsCoverageMetric)
                    .Select(metric => $"{metric.Label}: {metric.Value}{(string.IsNullOrWhiteSpace(metric.Delta) ? string.Empty : $" ({metric.Delta})")}"));
            if (!string.IsNullOrWhiteSpace(coverageMetrics))
            {
                signals.Add(coverageMetrics);
            }

            if (variant.OverlapBadges.Count > 0)
            {
                signals.Add($"Overlap: {string.Join(" | ", variant.OverlapBadges.Select(badge => badge.Label))}");
            }

            if (signals.Count > 0)
            {
                lines.Add($"{variant.Label}: {string.Join(" · ", signals)}");
            }
        }

        foreach (BuildLabProgressionTimeline timeline in projection.ProgressionTimelines)
        {
            BuildLabProgressionStep? strongestCoverageStep = null;
            foreach (BuildLabProgressionStep step in timeline.Steps)
            {
                if (step.Outcomes.Any(IsCoverageMetric))
                {
                    strongestCoverageStep = step;
                }
            }

            if (strongestCoverageStep is null)
            {
                lines.Add($"{timeline.Title}: {timeline.Steps.Count} checkpoint(s) keep the plan ready for handoff.");
                continue;
            }

            string coverageOutcomes = string.Join(
                " | ",
                strongestCoverageStep.Outcomes
                    .Where(IsCoverageMetric)
                    .Select(metric => $"{metric.Label}: {metric.Value}"));
            lines.Add($"{timeline.Title}: strongest coverage checkpoint at {strongestCoverageStep.KarmaTarget} Karma · {coverageOutcomes}");
        }

        return lines;
    }

    private static bool HasCoverageSignals(BuildLabVariantProjection variant)
    {
        return variant.OverlapBadges.Count > 0 || variant.Metrics.Any(IsCoverageMetric);
    }

    private static IReadOnlyList<string> BuildTeamCoverageLines(BuildLabTeamCoverageProjection? teamCoverage)
    {
        if (teamCoverage is null)
        {
            return [];
        }

        List<string> lines = [];
        if (!string.IsNullOrWhiteSpace(teamCoverage.CoverageSummary))
        {
            lines.Add($"Coverage: {teamCoverage.CoverageSummary}");
        }

        if (!string.IsNullOrWhiteSpace(teamCoverage.RolePressureSummary))
        {
            lines.Add($"Role pressure: {teamCoverage.RolePressureSummary}");
        }

        if (teamCoverage.CoveredRoleTags is { Count: > 0 })
        {
            lines.Add($"Covered roles: {FormatRoleTags(teamCoverage.CoveredRoleTags)}");
        }

        if (teamCoverage.MissingRoleTags.Count > 0)
        {
            lines.Add($"Missing roles: {FormatRoleTags(teamCoverage.MissingRoleTags)}");
        }

        if (teamCoverage.DuplicateRoleTags is { Count: > 0 })
        {
            lines.Add($"Duplicate roles: {FormatRoleTags(teamCoverage.DuplicateRoleTags)}");
        }

        if (!string.IsNullOrWhiteSpace(teamCoverage.ExplainEntryId))
        {
            lines.Add($"Explain: {teamCoverage.ExplainEntryId}");
        }

        return lines;
    }

    private static string FormatRoleTags(IEnumerable<string> roleTags)
        => string.Join(" | ", roleTags.Select(FormatRoleTag));

    private static string FormatRoleTag(string roleTag)
    {
        string normalized = roleTag.Replace('-', ' ').Replace('_', ' ').Trim();
        return string.IsNullOrWhiteSpace(normalized)
            ? roleTag
            : System.Globalization.CultureInfo.InvariantCulture.TextInfo.ToTitleCase(normalized);
    }

    private static bool HasBuildBlockerReceipt(BuildLabConceptIntakeProjection projection)
    {
        return !projection.CanContinue
            || !string.IsNullOrWhiteSpace(projection.RuntimeCompatibilitySummary)
            || !string.IsNullOrWhiteSpace(projection.SupportClosureSummary)
            || projection.Watchouts is { Count: > 0 }
            || projection.Variants.Any(variant => variant.Warnings.Count > 0);
    }

    private static string BuildBuildBlockerBadge(BuildLabConceptIntakeProjection projection)
    {
        int warningCount = projection.Variants.Sum(static variant => variant.Warnings.Count)
            + (projection.Watchouts?.Count ?? 0);
        return warningCount == 0 && projection.CanContinue ? "receipt" : $"{warningCount} blocker signal(s)";
    }

    private static string BuildBuildBlockerEnvironment(BuildLabConceptIntakeProjection projection)
        => $"{projection.RulesetId} / {projection.BuildMethod}";

    private static string BuildBuildBlockerEnvironmentDiff(BuildLabConceptIntakeProjection projection)
        => $"{BuildBuildBlockerBefore(projection)} -> {BuildBuildBlockerAfter(projection)}";

    private static string BuildBuildBlockerBefore(BuildLabConceptIntakeProjection projection)
    {
        string summary = FirstNonBlank(
            projection.RuntimeCompatibilitySummary,
            projection.CampaignFitSummary,
            projection.Variants
                .SelectMany(static variant => variant.Warnings)
                .Select(static warning => warning.Detail)
                .FirstOrDefault(),
            projection.Watchouts?.FirstOrDefault());

        return string.IsNullOrWhiteSpace(summary) ? "No blocker was emitted before this build decision." : summary;
    }

    private static string BuildBuildBlockerAfter(BuildLabConceptIntakeProjection projection)
        => FirstNonBlank(
            projection.NextSafeAction,
            projection.SupportClosureSummary,
            projection.CanContinue ? "Build can continue with the current receipt." : "Resolve the blocker before handoff.");

    private static string BuildBuildBlockerExplainReceipt(BuildLabConceptIntakeProjection projection)
        => FirstNonBlank(
            projection.ExplainEntryId,
            projection.SourceDocumentId,
            $"{projection.RulesetId}/{projection.BuildMethod} blocker receipt");

    private static string BuildBuildBlockerSupport(BuildLabConceptIntakeProjection projection)
        => FirstNonBlank(
            projection.SupportClosureSummary,
            string.IsNullOrWhiteSpace(projection.ExplainEntryId)
                ? "Support can cite the visible blocker receipt."
                : $"Support can cite explain receipt {projection.ExplainEntryId}.");

    private static string FirstNonBlank(params string?[] values)
        => values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ?? string.Empty;

    private static bool IsCoverageMetric(BuildLabVariantMetric metric)
    {
        return metric.Label.Contains("coverage", StringComparison.OrdinalIgnoreCase)
            || metric.Label.Contains("role", StringComparison.OrdinalIgnoreCase);
    }
}
