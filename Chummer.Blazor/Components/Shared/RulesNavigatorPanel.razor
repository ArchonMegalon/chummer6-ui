@using Chummer.Campaign.Contracts
@using Chummer.Contracts.Rulesets
@using Chummer.Presentation.UiKit

<section class="panel design-panel" data-rules-navigator-showcase="@Projection.EntryId">
    <header class="panel-header">
        <div>
            <h2>Rules Navigator</h2>
            <p class="note">@Projection.Question</p>
        </div>
        <div class="button-row compact">
            <span class="@(ChummerPatternBoundary.ExplainChipClass(Projection.ProvenanceLabel, "Rules navigator provenance label"))"
                  @attributes="@(ChummerPatternBoundary.ExplainChipAttributes(Projection.ProvenanceLabel, "Rules navigator provenance label"))">@Projection.ProvenanceLabel</span>
            <span class="@(ChummerPatternBoundary.ExplainChipClass(Projection.ExplainEntryId, "Rules navigator explain entry", active: true))"
                  @attributes="@(ChummerPatternBoundary.ExplainChipAttributes(Projection.ExplainEntryId, "Rules navigator explain entry", active: true))">@Projection.ExplainEntryId</span>
        </div>
    </header>

    <section class="coach-card">
        <div class="coach-card-header">
            <h3>Grounded answer</h3>
            <span class="@(ChummerPatternBoundary.ExplainChipClass(GetDiffChipLabel(), "Rules navigator before and after diff"))"
                  @attributes="@(ChummerPatternBoundary.ExplainChipAttributes(GetDiffChipLabel(), "Rules navigator before and after diff"))">@GetDiffChipLabel()</span>
        </div>
        <p><strong>@Projection.ShortAnswer</strong></p>
        @if (Projection.Diffs is { Count: > 0 })
        {
            <ul class="browse-detail-lines">
                @foreach (RulesetEnvironmentDiffProjection diff in Projection.Diffs)
                {
                    <li>
                        <strong>@diff.Label</strong>
                        <span> Before: @diff.BeforeSummary</span>
                        <span> After: @diff.AfterSummary</span>
                        <span> Why: @diff.ReasonSummary</span>
                        @if (!string.IsNullOrWhiteSpace(diff.ExplainEntryId))
                        {
                            <span> Explain: @diff.ExplainEntryId</span>
                        }
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="note">Before: @Projection.BeforeSummary</p>
            <p class="note">After: @Projection.AfterSummary</p>
        }
    </section>

    <section class="coach-card">
        <div class="coach-card-header">
            <h3>Evidence + reuse</h3>
            <span class="@(ChummerPatternBoundary.ExplainChipClass($"{Projection.EvidenceLines.Count} evidence line(s)", "Rules navigator evidence line count"))"
                  @attributes="@(ChummerPatternBoundary.ExplainChipAttributes($"{Projection.EvidenceLines.Count} evidence line(s)", "Rules navigator evidence line count"))">@Projection.EvidenceLines.Count evidence line(s)</span>
        </div>
        <ul class="browse-detail-lines">
            @foreach (string line in Projection.EvidenceLines)
            {
                <li>@line</li>
            }
        </ul>
        <p class="note">@string.Join(" | ", Projection.SupportReuseHints)</p>
    </section>
</section>

@code {
    [Parameter, EditorRequired]
    public RulesNavigatorAnswerProjection Projection { get; set; } = new(
        EntryId: "rules-demo",
        Question: "Why is this rules posture active?",
        ShortAnswer: "Because the same approved compatibility fingerprint drives build, play, and support.",
        BeforeSummary: "Before approval, answers stay caveated and review-heavy.",
        AfterSummary: "After approval, one grounded answer path stays visible everywhere.",
        ExplainEntryId: "rules.navigator.demo",
        ProvenanceLabel: "campaign scope · sr6.preview.v1",
        EvidenceLines: ["sr6.preview.v1 is the active compatibility fingerprint."],
        SupportReuseHints: ["Support can reuse this answer instead of inventing new behavior."],
        Diffs:
        [
            new RulesetEnvironmentDiffProjection(
                DiffId: "rules.navigator.demo:return",
                Label: "Campaign return",
                BeforeSummary: "Before approval, answers stay caveated and review-heavy.",
                AfterSummary: "After approval, one grounded answer path stays visible everywhere.",
                ReasonSummary: "The campaign return stays pinned to the approved compatibility fingerprint.",
                ExplainEntryId: "rules.navigator.demo:return")
        ]);

    private string GetDiffChipLabel()
        => Projection.Diffs is { Count: > 0 }
            ? $"{Projection.Diffs.Count} before/after diff(s)"
            : "Before / after";
}
