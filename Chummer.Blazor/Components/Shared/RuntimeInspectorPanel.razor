@namespace Chummer.Blazor.Components.Shared

@using Chummer.Contracts.Content
@using Chummer.Contracts.Rulesets
@using Chummer.Presentation.Overview
@using Chummer.Presentation.UiKit

<section class="panel design-panel">
    <header class="panel-header">
        <div>
            <h2>Runtime Inspector</h2>
            <p class="meta">Resolved runtime lock, compatibility diagnostics, and provider bindings rendered from shared contracts.</p>
        </div>
        @if (Projection is not null)
        {
            <div class="button-row compact">
                <span class="badge @GetInstallBadgeClass(Projection.Install.State)">@Projection.Install.State</span>
                <span class="badge">@Projection.RuntimeLock.RulesetId</span>
            </div>
        }
    </header>

    @if (Projection is null)
    {
        <p class="hint">No runtime projection is available.</p>
    }
    else
    {
        <section class="runtime-inspector-grid">
            <article class="panel trace-card">
                <header>
                    <h3>Runtime Identity</h3>
                    <span class="badge">@Projection.TargetKind</span>
                </header>
                <dl class="facts compact">
                    <div><dt>Target</dt><dd>@Projection.TargetId</dd></div>
                    <div><dt>Profile Source</dt><dd>@Projection.ProfileSourceKind</dd></div>
                    <div><dt>Engine API</dt><dd>@Projection.RuntimeLock.EngineApiVersion</dd></div>
                    <div><dt>Fingerprint</dt><dd class="mono">@Projection.RuntimeLock.RuntimeFingerprint</dd></div>
                    <div><dt>Generated</dt><dd>@Projection.GeneratedAtUtc.ToLocalTime().ToString("u")</dd></div>
                    <div><dt>Install Target</dt><dd>@RuntimeInspectorDiagnostics.FormatInstallTarget(Projection.Install)</dd></div>
                </dl>
            </article>

            <article class="panel trace-card">
                <header>
                    <h3>Rule Profile</h3>
                    <span class="badge">@GetProfileBadgeText(Projection)</span>
                </header>
                <dl class="facts compact">
                    <div><dt>Profile</dt><dd>@Projection.TargetId</dd></div>
                    <div><dt>Install State</dt><dd>@Projection.Install.State</dd></div>
                    <div><dt>Install Target</dt><dd>@RuntimeInspectorDiagnostics.FormatInstallTarget(Projection.Install)</dd></div>
                    <div><dt>Session-safe Bindings</dt><dd>@RuntimeInspectorDiagnostics.CountProfileSessionSafeBindings(Projection)/@Projection.ProviderBindings.Count</dd></div>
                    <div><dt>Attention Items</dt><dd>@RuntimeInspectorDiagnostics.CountProfileAttentionItems(Projection)</dd></div>
                    <div><dt>Generated</dt><dd>@Projection.GeneratedAtUtc.ToLocalTime().ToString("u")</dd></div>
                </dl>
            </article>

            <article class="panel trace-card">
                <header>
                    <h3>Runtime Footprint</h3>
                    <span class="badge">@Projection.ResolvedRulePacks.Count packs</span>
                </header>
                <dl class="facts compact">
                    <div><dt>Content Bundles</dt><dd>@Projection.RuntimeLock.ContentBundles.Count</dd></div>
                    <div><dt>Provider Bindings</dt><dd>@Projection.ProviderBindings.Count</dd></div>
                    <div><dt>Warnings</dt><dd>@Projection.Warnings.Count</dd></div>
                    <div><dt>Migration Items</dt><dd>@Projection.MigrationPreview.Count</dd></div>
                    <div><dt>Compatibility</dt><dd>@Projection.CompatibilityDiagnostics.Count</dd></div>
                    <div><dt>Capabilities</dt><dd>@(Projection.CapabilityDescriptors?.Count ?? 0)</dd></div>
                </dl>
            </article>
        </section>

        <article class="panel trace-card" data-runtime-rule-profile-diagnostics>
            <header>
                <h3>Rule Profile Diagnostics</h3>
                <span class="badge">@RuntimeInspectorDiagnostics.CountProfileAttentionItems(Projection) attention</span>
            </header>
            <dl class="facts compact">
                <div><dt>Runtime Lock</dt><dd class="mono">@Projection.RuntimeLock.RuntimeFingerprint</dd></div>
                <div><dt>Ruleset</dt><dd>@Projection.RuntimeLock.RulesetId</dd></div>
                <div><dt>Engine API</dt><dd>@Projection.RuntimeLock.EngineApiVersion</dd></div>
                <div><dt>Profile Source</dt><dd>@Projection.ProfileSourceKind</dd></div>
                @if (Projection.Promotion is not null)
                {
                    <div><dt>Publication</dt><dd>@Projection.Promotion.PublicationStatus</dd></div>
                    <div><dt>Visibility</dt><dd>@Projection.Promotion.Visibility</dd></div>
                    <div><dt>Update Channel</dt><dd>@Projection.Promotion.UpdateChannel</dd></div>
                    <div><dt>Current Stage</dt><dd>@FormatPromotionStage(Projection.Promotion.CurrentStage)</dd></div>
                    <div><dt>Promote To</dt><dd>@FormatPromotionStage(Projection.Promotion.PromotionTargetStage)</dd></div>
                    <div><dt>Published</dt><dd>@(Projection.Promotion.PublishedAtUtc?.ToLocalTime().ToString("u") ?? "not published yet")</dd></div>
                    <div><dt>Promotion</dt><dd>@Projection.Promotion.PromotionSummary</dd></div>
                    <div><dt>Rollback</dt><dd>@Projection.Promotion.RollbackSummary</dd></div>
                    <div><dt>Lineage</dt><dd>@Projection.Promotion.LineageSummary</dd></div>
                }
                <div><dt>Provider Coverage</dt><dd>@Projection.ProviderBindings.Count bindings across @(Projection.CapabilityDescriptors?.Count ?? 0) capability descriptors</dd></div>
                <div><dt>Summary</dt><dd>@RuntimeInspectorDiagnostics.BuildProfileDiagnosticsSummary(Projection)</dd></div>
            </dl>
            @if (Projection.Promotion is not null)
            {
                <ul class="browse-detail-lines">
                    @foreach (var stage in BuildPromotionFlow(Projection.Promotion))
                    {
                        <li><strong>@stage.Label</strong><span> @stage.Status:</span><span> @stage.Summary</span></li>
                    }
                </ul>
            }
        </article>

        <article class="panel trace-card" data-runtime-hub-diagnostics>
            <header>
                <h3>Hub Client Diagnostics</h3>
                <span class="badge">@RuntimeInspectorDiagnostics.CountHubOriginRulePacks(Projection)/@Projection.ResolvedRulePacks.Count hub-origin</span>
            </header>
            <dl class="facts compact">
                <div><dt>Hub Profile Source</dt><dd>@Projection.ProfileSourceKind</dd></div>
                <div><dt>Hub-origin RulePacks</dt><dd>@RuntimeInspectorDiagnostics.CountHubOriginRulePacks(Projection) of @Projection.ResolvedRulePacks.Count resolved packs</dd></div>
                <div><dt>Install Visibility</dt><dd>@Projection.Install.State via @RuntimeInspectorDiagnostics.FormatInstallTarget(Projection.Install)</dd></div>
                <div><dt>Review State</dt><dd>@(RuntimeInspectorDiagnostics.HasStaleOrInvalidatedState(Projection) ? "review required" : "review current")</dd></div>
                <div><dt>Update State</dt><dd>@(RuntimeInspectorDiagnostics.HasStaleOrInvalidatedState(Projection) ? "refresh pending" : "no refresh required")</dd></div>
                <div><dt>Stale/Invalidation</dt><dd>@(RuntimeInspectorDiagnostics.HasStaleOrInvalidatedState(Projection) ? "action required" : "none")</dd></div>
                <div><dt>Summary</dt><dd>@RuntimeInspectorDiagnostics.BuildHubClientDiagnosticsSummary(Projection)</dd></div>
            </dl>
        </article>

        <article class="panel trace-card">
            <header>
                <h3>Content Bundles</h3>
                <span class="badge">@Projection.RuntimeLock.ContentBundles.Count</span>
            </header>
            @if (Projection.RuntimeLock.ContentBundles.Count == 0)
            {
                <p class="hint">No content bundles are pinned into this runtime.</p>
            }
            else
            {
                <table class="section-table">
                    <thead>
                        <tr>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("bundle", "Bundle"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("bundle", "Bundle"))">Bundle</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("ruleset", "Ruleset"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("ruleset", "Ruleset"))">Ruleset</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("version", "Version"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("version", "Version"))">Version</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("assets", "Assets"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("assets", "Assets"))">Assets</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ContentBundleDescriptor bundle in Projection.RuntimeLock.ContentBundles)
                        {
                            <tr class="@(ChummerPatternBoundary.DenseRowClass($"bundle-{bundle.BundleId}"))" @attributes="@(ChummerPatternBoundary.DenseRowAttributes($"bundle-{bundle.BundleId}"))">
                                <td>@bundle.Title</td>
                                <td>@bundle.RulesetId</td>
                                <td>@bundle.Version</td>
                                <td>@bundle.AssetPaths.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </article>

        <article class="panel trace-card">
            <header>
                <h3>Rule Packs</h3>
                <span class="badge">@Projection.ResolvedRulePacks.Count</span>
            </header>
            @if (Projection.ResolvedRulePacks.Count == 0)
            {
                <p class="hint">No RulePacks are resolved for this runtime.</p>
            }
            else
            {
                <ul class="runtime-list">
                    @foreach (RuntimeInspectorRulePackEntry rulePack in Projection.ResolvedRulePacks)
                    {
                        <li>
                            <div class="coach-card-header">
                                <div>
                                    <strong>@rulePack.Title</strong>
                                    <p class="meta">@rulePack.RulePack.Id@("@")@rulePack.RulePack.Version · @rulePack.SourceKind</p>
                                </div>
                                <span class="badge @GetTrustBadgeClass(rulePack.TrustTier)">@rulePack.TrustTier</span>
                            </div>
                            <p class="hint">Visibility: @rulePack.Visibility · Capabilities: @FormatCapabilityIds(rulePack.CapabilityIds)</p>
                        </li>
                    }
                </ul>
            }
        </article>

        <article class="panel trace-card" data-runtime-rulepack-diagnostics>
            <header>
                <h3>Rule Pack Diagnostics</h3>
                <span class="badge">@Projection.ResolvedRulePacks.Count tracked</span>
            </header>
            @if (Projection.ResolvedRulePacks.Count == 0)
            {
                <p class="hint">No RulePack diagnostics are available because no packs are resolved for this runtime.</p>
            }
            else
            {
                <table class="section-table">
                    <thead>
                        <tr>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("rulepack", "RulePack"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("rulepack", "RulePack"))">RulePack</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("trust", "Trust"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("trust", "Trust"))">Trust</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("bindings", "Bindings"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("bindings", "Bindings"))">Bindings</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("warnings", "Warnings"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("warnings", "Warnings"))">Warnings</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("migration", "Migration"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("migration", "Migration"))">Migration</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("capabilities", "Capabilities"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("capabilities", "Capabilities"))">Capabilities</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (RuntimeInspectorRulePackEntry rulePack in Projection.ResolvedRulePacks)
                        {
                            <tr class="@(ChummerPatternBoundary.DenseRowClass($"rulepack-{rulePack.RulePack.Id}"))"
                                @attributes="@(ChummerPatternBoundary.DenseRowAttributes($"rulepack-{rulePack.RulePack.Id}"))"
                                data-runtime-rulepack-row="@rulePack.RulePack.Id">
                                <td>
                                    <strong>@rulePack.Title</strong>
                                    <div class="meta">@rulePack.RulePack.Id@("@")@rulePack.RulePack.Version · @rulePack.SourceKind</div>
                                </td>
                                <td>@rulePack.TrustTier / @rulePack.Visibility</td>
                                <td>@RuntimeInspectorDiagnostics.CountRulePackProviderBindings(Projection, rulePack)</td>
                                <td>@RuntimeInspectorDiagnostics.CountRulePackWarnings(Projection, rulePack)</td>
                                <td>@RuntimeInspectorDiagnostics.CountRulePackMigrationItems(Projection, rulePack)</td>
                                <td>@FormatCapabilityIds(rulePack.CapabilityIds)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </article>

        <article class="panel trace-card">
            <header>
                <h3>Provider Bindings</h3>
                <span class="badge">@Projection.ProviderBindings.Count</span>
            </header>
            @if (Projection.ProviderBindings.Count == 0)
            {
                <p class="hint">No provider bindings are active.</p>
            }
            else
            {
                <table class="section-table">
                    <thead>
                        <tr>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("capability", "Capability"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("capability", "Capability"))">Capability</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("provider", "Provider"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("provider", "Provider"))">Provider</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("pack", "Pack"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("pack", "Pack"))">Pack</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("session-safe", "Session Safe"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("session-safe", "Session Safe"))">Session Safe</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (RuntimeInspectorProviderBinding binding in Projection.ProviderBindings)
                        {
                            <tr class="@(ChummerPatternBoundary.DenseRowClass($"binding-{binding.CapabilityId}", explainAffinity: binding.SessionSafe, muted: !binding.SessionSafe))"
                                @attributes="@(ChummerPatternBoundary.DenseRowAttributes($"binding-{binding.CapabilityId}", explainAffinity: binding.SessionSafe, muted: !binding.SessionSafe))">
                                <td>@binding.CapabilityId</td>
                                <td>@binding.ProviderId</td>
                                <td>@(binding.PackId ?? "(none)")</td>
                                <td>@(binding.SessionSafe ? "yes" : "no")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </article>

        <article class="panel trace-card">
            <header>
                <h3>Compatibility Diagnostics</h3>
                <span class="badge">@Projection.CompatibilityDiagnostics.Count</span>
            </header>
            @if (Projection.CompatibilityDiagnostics.Count == 0)
            {
                <p class="hint">No compatibility diagnostics were emitted.</p>
            }
            else
            {
                <ul class="runtime-list">
                    @foreach (RuntimeLockCompatibilityDiagnostic diagnostic in Projection.CompatibilityDiagnostics)
                    {
                        <li>
                            <div class="coach-card-header">
                                <strong>@diagnostic.Message</strong>
                                <span class="badge @GetCompatibilityBadgeClass(diagnostic.State)">@diagnostic.State</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(diagnostic.RequiredRuntimeFingerprint) || !string.IsNullOrWhiteSpace(diagnostic.RequiredRulesetId))
                            {
                                <p class="hint">
                                    Required runtime: @(diagnostic.RequiredRuntimeFingerprint ?? "(current)")
                                    · Required ruleset: @(diagnostic.RequiredRulesetId ?? "(current)")
                                </p>
                            }
                        </li>
                    }
                </ul>
            }
        </article>

        <article class="panel trace-card">
            <header>
                <h3>Warnings</h3>
                <span class="badge">@Projection.Warnings.Count</span>
            </header>
            @if (Projection.Warnings.Count == 0)
            {
                <p class="hint">No runtime warnings are active.</p>
            }
            else
            {
                <ul class="runtime-list">
                    @foreach (RuntimeInspectorWarning warning in Projection.Warnings)
                    {
                        <li>
                            <div class="coach-card-header">
                                <strong>@warning.Message</strong>
                                <span class="badge @GetWarningBadgeClass(warning.Severity)">@warning.Severity</span>
                            </div>
                            <p class="hint">Kind: @warning.Kind · Subject: @(warning.SubjectId ?? "(none)")</p>
                        </li>
                    }
                </ul>
            }
        </article>

        <article class="panel trace-card">
            <header>
                <h3>Migration Preview</h3>
                <span class="badge">@Projection.MigrationPreview.Count</span>
            </header>
            @if (Projection.MigrationPreview.Count == 0)
            {
                <p class="hint">No migration preview items were generated.</p>
            }
            else
            {
                <ul class="runtime-list">
                    @foreach (RuntimeMigrationPreviewItem item in Projection.MigrationPreview)
                    {
                        <li>
                            <div class="coach-card-header">
                                <strong>@item.Summary</strong>
                                <span class="badge @(item.RequiresRebind ? "coach-badge warn" : "coach-badge good")">@item.Kind</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.BeforeValue) || !string.IsNullOrWhiteSpace(item.AfterValue))
                            {
                                <p class="hint">Before: @(item.BeforeValue ?? "(none)") · After: @(item.AfterValue ?? "(none)")</p>
                            }
                        </li>
                    }
                </ul>
            }
        </article>

        @if (HasDiagnosticsEnvironmentDiff(Projection))
        {
            <article class="panel trace-card" data-diagnostics-environment-diff>
                <header>
                    <h3>Diagnostics environment diff</h3>
                    <span class="badge">@BuildDiagnosticsDiffBadge(Projection)</span>
                </header>
                <dl class="facts compact">
                    <div><dt>Rule environment</dt><dd>@Projection.RuntimeLock.RulesetId · @Projection.RuntimeLock.RuntimeFingerprint</dd></div>
                    <div><dt>Before</dt><dd>@BuildDiagnosticsDiffBefore(Projection)</dd></div>
                    <div><dt>After</dt><dd>@BuildDiagnosticsDiffAfter(Projection)</dd></div>
                    <div><dt>Explain receipt</dt><dd>@BuildDiagnosticsExplainReceipt(Projection)</dd></div>
                    <div><dt>Support reuse</dt><dd>@RuntimeInspectorDiagnostics.BuildHubClientDiagnosticsSummary(Projection)</dd></div>
                </dl>
            </article>
        }

        <article class="panel trace-card">
            <header>
                <h3>Capability Descriptors</h3>
                <span class="badge">@(Projection.CapabilityDescriptors?.Count ?? 0)</span>
            </header>
            @if (Projection.CapabilityDescriptors is not { Count: > 0 })
            {
                <p class="hint">No capability descriptors were supplied for this runtime.</p>
            }
            else
            {
                <table class="section-table">
                    <thead>
                        <tr>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("descriptor-capability", "Capability"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("descriptor-capability", "Capability"))">Capability</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("invocation", "Invocation"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("invocation", "Invocation"))">Invocation</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("descriptor-provider", "Provider"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("descriptor-provider", "Provider"))">Provider</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("flags", "Flags"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("flags", "Flags"))">Flags</th>
                            <th class="@(ChummerPatternBoundary.DenseHeaderClass("gas", "Gas"))" @attributes="@(ChummerPatternBoundary.DenseHeaderAttributes("gas", "Gas"))">Gas</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (RuntimeInspectorCapabilityDescriptorProjection descriptor in Projection.CapabilityDescriptors)
                        {
                            <tr class="@(ChummerPatternBoundary.DenseRowClass($"descriptor-{descriptor.CapabilityId}", explainAffinity: descriptor.Explainable, muted: !descriptor.SessionSafe))"
                                @attributes="@(ChummerPatternBoundary.DenseRowAttributes($"descriptor-{descriptor.CapabilityId}", explainAffinity: descriptor.Explainable, muted: !descriptor.SessionSafe))">
                                <td>@descriptor.Title</td>
                                <td>@descriptor.InvocationKind</td>
                                <td>@(descriptor.ProviderId ?? "(none)")</td>
                                <td>@FormatCapabilityFlags(descriptor)</td>
                                <td>@FormatGasBudget(descriptor.DefaultGasBudget)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </article>
    }
</section>

@code {
    [Parameter]
    public RuntimeInspectorProjection? Projection { get; set; }

    private static string FormatCapabilityIds(IReadOnlyList<string> capabilityIds)
        => capabilityIds.Count == 0 ? "(none)" : string.Join(", ", capabilityIds);

    private static string FormatCapabilityFlags(RuntimeInspectorCapabilityDescriptorProjection descriptor)
    {
        List<string> flags = [];
        if (descriptor.Explainable)
        {
            flags.Add("explainable");
        }

        if (descriptor.SessionSafe)
        {
            flags.Add("session-safe");
        }

        if (!string.IsNullOrWhiteSpace(descriptor.PackId))
        {
            flags.Add($"pack:{descriptor.PackId}");
        }

        return flags.Count == 0 ? "(none)" : string.Join(", ", flags);
    }

    private static string FormatGasBudget(RulesetGasBudget budget)
        => $"{budget.ProviderInstructionLimit}/{budget.RequestInstructionLimit} · {budget.MemoryBytesLimit / 1024 / 1024} MB";

    private static string GetProfileBadgeText(RuntimeInspectorProjection projection)
        => RuntimeInspectorDiagnostics.CountProfileAttentionItems(projection) == 0 ? "stable" : "attention";

    private static string GetInstallBadgeClass(string installState)
        => installState switch
        {
            ArtifactInstallStates.Pinned => "coach-badge good",
            ArtifactInstallStates.Installed => "coach-badge warn",
            _ => string.Empty
        };

    private static string GetTrustBadgeClass(string trustTier)
        => trustTier switch
        {
            ArtifactTrustTiers.Official => "coach-badge good",
            ArtifactTrustTiers.Curated => "coach-badge warn",
            _ => string.Empty
        };

    private static string GetCompatibilityBadgeClass(string state)
        => state switch
        {
            RuntimeLockCompatibilityStates.Compatible => "coach-badge good",
            RuntimeLockCompatibilityStates.RebindRequired => "coach-badge warn",
            _ => "coach-badge error"
        };

    private static string GetWarningBadgeClass(string severity)
        => severity switch
        {
            RuntimeInspectorWarningSeverityLevels.Info => "coach-badge good",
            RuntimeInspectorWarningSeverityLevels.Warning => "coach-badge warn",
            _ => "coach-badge error"
        };

    private static bool HasDiagnosticsEnvironmentDiff(RuntimeInspectorProjection projection)
        => projection.MigrationPreview.Count > 0
            || projection.CompatibilityDiagnostics.Count > 0
            || projection.Warnings.Count > 0
            || projection.ProviderBindings.Any(static binding => !binding.SessionSafe);

    private static string BuildDiagnosticsDiffBadge(RuntimeInspectorProjection projection)
    {
        int diffCount = projection.MigrationPreview.Count
            + projection.CompatibilityDiagnostics.Count
            + projection.Warnings.Count;
        return diffCount == 0 ? "stable" : $"{diffCount} diff signal(s)";
    }

    private static string BuildDiagnosticsDiffBefore(RuntimeInspectorProjection projection)
    {
        RuntimeMigrationPreviewItem? migration = projection.MigrationPreview
            .FirstOrDefault(static item => !string.IsNullOrWhiteSpace(item.BeforeValue));
        if (migration is not null)
        {
            return $"{migration.SubjectId ?? migration.Kind}: {migration.BeforeValue}";
        }

        RuntimeLockCompatibilityDiagnostic? diagnostic = projection.CompatibilityDiagnostics.FirstOrDefault();
        if (diagnostic is not null)
        {
            return $"{projection.RuntimeLock.RulesetId} / {projection.RuntimeLock.RuntimeFingerprint}: {diagnostic.Message}";
        }

        RuntimeInspectorWarning? warning = projection.Warnings.FirstOrDefault();
        return warning is null
            ? "Current rule environment has no emitted before-state drift."
            : $"{warning.SubjectId ?? warning.Kind}: {warning.Message}";
    }

    private static string BuildDiagnosticsDiffAfter(RuntimeInspectorProjection projection)
    {
        RuntimeMigrationPreviewItem? migration = projection.MigrationPreview
            .FirstOrDefault(static item => !string.IsNullOrWhiteSpace(item.AfterValue));
        RuntimeLockCompatibilityDiagnostic? diagnostic = projection.CompatibilityDiagnostics.FirstOrDefault();
        if (migration is not null)
        {
            string migrationAfter = $"{migration.SubjectId ?? migration.Kind}: {migration.AfterValue}";
            return diagnostic is null
                ? migrationAfter
                : $"{migrationAfter}; {BuildCompatibilityAfter(diagnostic, projection)}";
        }

        if (diagnostic is not null)
        {
            return BuildCompatibilityAfter(diagnostic, projection);
        }

        return RuntimeInspectorDiagnostics.HasStaleOrInvalidatedState(projection)
            ? "Refresh the runtime projection and keep the support packet open until the receipt is current."
            : "No environment change is required before support closure.";
    }

    private static string BuildCompatibilityAfter(RuntimeLockCompatibilityDiagnostic diagnostic, RuntimeInspectorProjection projection)
        => string.IsNullOrWhiteSpace(diagnostic.RequiredRuntimeFingerprint)
            ? $"Recheck required ruleset {diagnostic.RequiredRulesetId ?? projection.RuntimeLock.RulesetId} before support closure."
            : $"Rebind to {diagnostic.RequiredRuntimeFingerprint} before support closure.";

    private static string BuildDiagnosticsExplainReceipt(RuntimeInspectorProjection projection)
    {
        RuntimeInspectorCapabilityDescriptorProjection? descriptor = projection.CapabilityDescriptors?
            .FirstOrDefault(static candidate => candidate.Explainable);
        if (descriptor is not null)
        {
            return $"{descriptor.CapabilityId} via {descriptor.ProviderId ?? "(provider pending)"}";
        }

        RuntimeInspectorProviderBinding? binding = projection.ProviderBindings.FirstOrDefault();
        return binding is null ? "No explainable provider binding is active." : $"{binding.CapabilityId} via {binding.ProviderId}";
    }
}

@code {
    private static IReadOnlyList<(string Label, string Status, string Summary)> BuildPromotionFlow(RuntimeInspectorPromotionProjection promotion)
    {
        string currentStage = promotion.CurrentStage ?? string.Empty;
        string targetStage = promotion.PromotionTargetStage ?? string.Empty;

        return
        [
            BuildPromotionFlowStage(RuntimeInspectorPromotionStages.Sandbox, "Sandbox", currentStage, targetStage, "Keep the rule environment bounded while preview work, local validation, and compatibility proof settle."),
            BuildPromotionFlowStage(RuntimeInspectorPromotionStages.CampaignApproved, "Campaign-approved", currentStage, targetStage, "Bind the same fingerprint to governed campaign truth so build, play, and support stop drifting."),
            BuildPromotionFlowStage(RuntimeInspectorPromotionStages.Published, "Published", currentStage, targetStage, "Promote the governed fingerprint for broader reuse only after the rollback and lineage posture are already explicit.")
        ];
    }

    private static (string Label, string Status, string Summary) BuildPromotionFlowStage(
        string stageId,
        string label,
        string currentStage,
        string targetStage,
        string summary)
    {
        string status = string.Equals(stageId, currentStage, StringComparison.Ordinal)
            ? "current"
            : string.Equals(stageId, targetStage, StringComparison.Ordinal)
                ? "next"
                : IsCompletedPromotionStage(stageId, currentStage)
                    ? "completed"
                    : "pending";

        return (label, status, summary);
    }

    private static string FormatPromotionStage(string? stage)
    {
        return stage switch
        {
            RuntimeInspectorPromotionStages.Sandbox => "Sandbox",
            RuntimeInspectorPromotionStages.CampaignApproved => "Campaign-approved",
            RuntimeInspectorPromotionStages.Published => "Published",
            _ => string.IsNullOrWhiteSpace(stage) ? "Not staged" : stage
        };
    }

    private static bool IsCompletedPromotionStage(string stageId, string currentStage)
    {
        return GetPromotionStageOrder(stageId) < GetPromotionStageOrder(currentStage);
    }

    private static int GetPromotionStageOrder(string? stageId)
    {
        return stageId switch
        {
            RuntimeInspectorPromotionStages.Sandbox => 0,
            RuntimeInspectorPromotionStages.CampaignApproved => 1,
            RuntimeInspectorPromotionStages.Published => 2,
            _ => -1
        };
    }
}
