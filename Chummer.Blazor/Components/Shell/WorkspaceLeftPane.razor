@namespace Chummer.Blazor.Components.Shell
@using Chummer.Contracts.Presentation
@using Chummer.Contracts.Rulesets
@using Chummer.Contracts.Workspaces
@using Chummer.Presentation.Rulesets
@using Chummer.Presentation.Shell

<aside class="left-pane">
    <OpenWorkspaceTree OpenWorkspaces="OpenWorkspaces"
                       ActiveWorkspaceId="ActiveWorkspaceId"
                       IsBusy="State.IsBusy"
                       OpenWorkspaceRequested="OpenWorkspaceRequested"
                       CloseWorkspaceRequested="CloseWorkspaceRequested" />

    @if (ShowSectionActions)
    {
        <section class="panel section-actions" aria-label="@BuildSectionActionsHeading()">
            <h2 class="visually-hidden">@BuildSectionActionsHeading()</h2>
            <div class="virtual-list action-grid">
                @* <Virtualize Items="@ActiveWorkspaceActions" ItemsTagName="ul" ItemTagName="li"> *@
                <Virtualize Items="@(ActiveWorkspaceActions.ToArray())"
                            Context="action"
                            ItemSize="40">
                    <button class="action-button @(State.ActiveActionId == action.Id ? "selected" : string.Empty)"
                            disabled="@State.IsBusy"
                            @onclick="() => ExecuteWorkspaceActionRequested.InvokeAsync(action)">
                        @FormatWorkspaceActionLabel(action)
                    </button>
                </Virtualize>
            </div>
        </section>
    }

    @if (ShowWorkflowSurfaces)
    {
        <section class="panel controls" aria-label="@BuildWorkflowSurfacesHeading()">
            <h2 class="visually-hidden">@BuildWorkflowSurfacesHeading()</h2>
            <div class="virtual-list mini-grid">
                @* <Virtualize Items="@ActiveWorkflowSurfaceActions" ItemsTagName="ul" ItemTagName="li"> *@
                <Virtualize Items="@(ActiveWorkflowSurfaceActions.ToArray())"
                            Context="surface"
                            ItemSize="36">
                    <button class="mini-btn"
                            data-workflow-surface="@surface.SurfaceId"
                            disabled="@State.IsBusy"
                            @onclick="() => ExecuteWorkflowSurfaceRequested.InvokeAsync(surface.ActionId)">
                        @FormatWorkflowSurfaceLabel(surface)
                    </button>
                </Virtualize>
            </div>
        </section>
    }
</aside>

@code {
    [Parameter]
    public CharacterOverviewState State { get; set; } = CharacterOverviewState.Empty;

    [Parameter]
    public IReadOnlyList<OpenWorkspaceState> OpenWorkspaces { get; set; } = [];

    [Parameter]
    public CharacterWorkspaceId? ActiveWorkspaceId { get; set; }

    [Parameter]
    public string? ActiveTabId { get; set; }

    [Parameter]
    public IReadOnlyList<NavigationTabDefinition> NavigationTabs { get; set; } = [];

    [Parameter]
    public IReadOnlyList<WorkspaceSurfaceActionDefinition> ActiveWorkspaceActions { get; set; } = [];

    [Parameter]
    public IReadOnlyList<WorkflowSurfaceActionBinding> ActiveWorkflowSurfaceActions { get; set; } = [];

    [Parameter]
    public Func<NavigationTabDefinition, bool> IsNavigationTabEnabled { get; set; } = _ => false;

    [Parameter]
    public EventCallback<string> OpenWorkspaceRequested { get; set; }

    [Parameter]
    public EventCallback<string> CloseWorkspaceRequested { get; set; }

    [Parameter]
    public EventCallback<string> SelectTabRequested { get; set; }

    [Parameter]
    public EventCallback<WorkspaceSurfaceActionDefinition> ExecuteWorkspaceActionRequested { get; set; }

    [Parameter]
    public EventCallback<string> ExecuteWorkflowSurfaceRequested { get; set; }

    private string BuildNavigationTabsHeading()
        => RulesetUiDirectiveCatalog.BuildNavigationTabsHeading(ResolveActiveRulesetId());

    private string BuildSectionActionsHeading()
        => RulesetUiDirectiveCatalog.BuildSectionActionsHeading(ResolveActiveRulesetId());

    private string BuildWorkflowSurfacesHeading()
        => RulesetUiDirectiveCatalog.BuildWorkflowSurfacesHeading(ResolveActiveRulesetId());

    private string FormatNavigationTabLabel(NavigationTabDefinition tab)
        => RulesetUiDirectiveCatalog.FormatNavigationTabLabel(tab.RulesetId, tab.Id, tab.Label);

    private string FormatWorkspaceActionLabel(WorkspaceSurfaceActionDefinition action)
        => RulesetUiDirectiveCatalog.FormatWorkspaceActionLabel(action.RulesetId, action.Id, action.TargetId, action.Label);

    private string FormatWorkflowSurfaceLabel(WorkflowSurfaceActionBinding surface)
        => RulesetUiDirectiveCatalog.FormatWorkflowSurfaceLabel(ResolveActiveRulesetId(), surface.ActionId, surface.Label);

    private bool ShowSectionActions =>
        ActiveWorkspaceId is not null && ActiveWorkspaceActions.Count > 0;

    private bool ShowWorkflowSurfaces =>
        ActiveWorkspaceId is not null && ActiveWorkflowSurfaceActions.Count > 0;

    private string? ResolveActiveRulesetId()
    {
        string? workspaceRulesetId = OpenWorkspaces
            .FirstOrDefault(workspace => string.Equals(workspace.Id.Value, ActiveWorkspaceId?.Value, StringComparison.Ordinal))
            ?.RulesetId;
        return RulesetDefaults.NormalizeOptional(NavigationTabs.FirstOrDefault()?.RulesetId)
            ?? RulesetDefaults.NormalizeOptional(ActiveWorkspaceActions.FirstOrDefault()?.RulesetId)
            ?? RulesetDefaults.NormalizeOptional(workspaceRulesetId)
            ?? RulesetDefaults.NormalizeOptional(OpenWorkspaces.FirstOrDefault()?.RulesetId);
    }
}
