@namespace Chummer.Blazor.Components.Shell
@using Chummer.Presentation.Overview
@using Chummer.Presentation.Rulesets
@using Chummer.Contracts.Workspaces

<div class="mdi-strip" id="mdiStrip">
    @if (OpenWorkspaces.Count == 0)
    {
        <span class="mdi-doc">@BuildWorkspaceStripEmptyState()</span>
    }
    else
    {
        @foreach (OpenWorkspaceState workspace in OpenWorkspaces)
        {
            bool isActive = string.Equals(ActiveWorkspaceId?.Value, workspace.Id.Value, StringComparison.Ordinal);
            string workspaceLabel = string.IsNullOrWhiteSpace(workspace.Alias) ? workspace.Name : $"{workspace.Name} ({workspace.Alias})";
            <span class="mdi-doc-wrap">
                <button class="mdi-doc @(isActive ? "active" : string.Empty)"
                        title="@BuildWorkspaceTitle(workspace)"
                        disabled="@IsBusy"
                        @onclick="() => OpenWorkspaceAsync(workspace.Id.Value)">
                    @($"{workspaceLabel}{(workspace.HasSavedWorkspace ? string.Empty : " *")}")
                </button>
                <button class="mdi-close"
                        title="Close workspace"
                        disabled="@IsBusy"
                        @onclick="() => CloseWorkspaceAsync(workspace.Id.Value)">
                    x
                </button>
            </span>
        }
    }
</div>

@code {
    [Parameter]
    public string? RulesetId { get; set; }

    [Parameter]
    public IReadOnlyList<OpenWorkspaceState> OpenWorkspaces { get; set; } = [];

    [Parameter]
    public CharacterWorkspaceId? ActiveWorkspaceId { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback<string> OpenWorkspaceRequested { get; set; }

    [Parameter]
    public EventCallback<string> CloseWorkspaceRequested { get; set; }

    private Task OpenWorkspaceAsync(string workspaceId)
    {
        return OpenWorkspaceRequested.InvokeAsync(workspaceId);
    }

    private Task CloseWorkspaceAsync(string workspaceId)
    {
        return CloseWorkspaceRequested.InvokeAsync(workspaceId);
    }

    private string BuildWorkspaceStripEmptyState()
        => RulesetUiDirectiveCatalog.BuildWorkspaceStripEmptyState(RulesetId);

    private static string BuildWorkspaceTitle(OpenWorkspaceState workspace)
        => RulesetUiDirectiveCatalog.BuildWorkspaceStripTitle(workspace.RulesetId, workspace.Id.Value, workspace.HasSavedWorkspace);
}
