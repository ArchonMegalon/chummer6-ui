@namespace Chummer.Blazor.Components.Shell
@using Chummer.Presentation.Rulesets
@using Chummer.Presentation.Overview
@using Microsoft.AspNetCore.Components.Forms

<section class="panel import">
    <h2>@BuildImportHeading()</h2>
    <p class="hint">@BuildImportHint()</p>
    <InputFile OnChange="ImportFileRequested"
               accept="@BuildImportAcceptAttribute()"
               disabled="@IsBusy" />
    <p class="hint">File: @(ImportedFileName ?? BuildImportFilePlaceholder())</p>
    @if (!string.IsNullOrWhiteSpace(ImportError))
    {
        <p class="error">@ImportError</p>
    }
    @if (LatestPortabilityActivity is { } activity)
    {
        <section class="coach-card" data-import-explain-receipt>
            <div class="coach-card-header">
                <h3>Import receipt</h3>
                <span class="badge">@activity.Receipt.CompatibilityState</span>
            </div>
            <dl class="facts compact">
                <div><dt>Receipt</dt><dd>@activity.Receipt.ReceiptSummary</dd></div>
                <div><dt>Environment</dt><dd>@activity.Receipt.ContextSummary</dd></div>
                <div><dt>Before</dt><dd>@BuildImportDiffBefore(activity.Receipt)</dd></div>
                <div><dt>After</dt><dd>@BuildImportDiffAfter(activity.Receipt)</dd></div>
                <div><dt>Provenance</dt><dd>@activity.Receipt.ProvenanceSummary</dd></div>
                <div><dt>Next safe action</dt><dd>@activity.Receipt.NextSafeAction</dd></div>
                <div><dt>Support reuse</dt><dd>@BuildImportSupportReuse(activity.Receipt)</dd></div>
            </dl>
            @if (activity.Receipt.Notes.Count > 0)
            {
                <ul class="browse-detail-lines">
                    @foreach (var note in activity.Receipt.Notes.Take(3))
                    {
                        <li><strong>@note.Severity:</strong> @note.Summary</li>
                    }
                </ul>
            }
        </section>
    }
    <details>
        <summary>@BuildImportDebugHeading()</summary>
        <textarea value="@RawImportXml" rows="8" @oninput="OnRawImportXmlChanged"></textarea>
        <button @onclick="ImportRawRequested" disabled="@IsBusy">@BuildImportRawActionLabel()</button>
    </details>
</section>

@code {
    [Parameter]
    public string? RulesetId { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public string? ImportedFileName { get; set; }

    [Parameter]
    public string? ImportError { get; set; }

    [Parameter]
    public WorkspacePortabilityActivity? LatestPortabilityActivity { get; set; }

    [Parameter]
    public string RawImportXml { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> RawImportXmlChanged { get; set; }

    [Parameter]
    public EventCallback<InputFileChangeEventArgs> ImportFileRequested { get; set; }

    [Parameter]
    public EventCallback ImportRawRequested { get; set; }

    private Task OnRawImportXmlChanged(ChangeEventArgs args)
    {
        return RawImportXmlChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
    }

    private string BuildImportHeading()
        => RulesetUiDirectiveCatalog.BuildImportHeading(RulesetId);

    private string BuildImportAcceptAttribute()
        => RulesetUiDirectiveCatalog.BuildImportAcceptAttribute(RulesetId);

    private string BuildImportHint()
        => RulesetUiDirectiveCatalog.BuildImportHint(RulesetId);

    private string BuildImportFilePlaceholder()
        => RulesetUiDirectiveCatalog.BuildImportFilePlaceholder(RulesetId);

    private string BuildImportDebugHeading()
        => RulesetUiDirectiveCatalog.BuildImportDebugHeading(RulesetId);

    private string BuildImportRawActionLabel()
        => RulesetUiDirectiveCatalog.BuildImportRawActionLabel(RulesetId);

    private static string BuildImportDiffBefore(WorkspacePortabilityReceipt receipt)
        => string.IsNullOrWhiteSpace(receipt.ContextSummary)
            ? $"Incoming {receipt.FormatId} payload before workspace merge."
            : receipt.ContextSummary;

    private static string BuildImportDiffAfter(WorkspacePortabilityReceipt receipt)
    {
        string? warning = receipt.Notes
            .FirstOrDefault(static note => !string.Equals(note.Severity, WorkspacePortabilityNoteSeverities.Info, StringComparison.OrdinalIgnoreCase))
            ?.Summary;

        return string.IsNullOrWhiteSpace(warning)
            ? receipt.NextSafeAction
            : $"{receipt.NextSafeAction} Diff signal: {warning}";
    }

    private static string BuildImportSupportReuse(WorkspacePortabilityReceipt receipt)
        => string.IsNullOrWhiteSpace(receipt.PayloadSha256)
            ? receipt.ProvenanceSummary
            : $"Support can cite payload {receipt.PayloadSha256} with {receipt.CompatibilityState} compatibility.";
}
