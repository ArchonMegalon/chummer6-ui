@namespace Chummer.Blazor.Components.Shell
@using Chummer.Presentation.UiKit
@using Chummer.Presentation.Overview
@using Microsoft.AspNetCore.Components
@* m104: blazor_dialog_surface *@
@if (Dialog is { } dialog)
{
    <div id="dialogBackdrop" class="dialog-backdrop" @onclick="CloseAsync">
        <div class="desktop-dialog"
             @ref="_dialogRoot"
             role="@AccessibilityPrimitiveBoundary.DialogRole"
             aria-modal="true"
             aria-labelledby="dialogTitle"
             aria-describedby="@AccessibilityPrimitiveBoundary.BuildDialogDescriptionId(dialog.Id)"
             tabindex="-1"
             @onclick:stopPropagation="true">
            <div class="dialog-titlebar">
                <span id="dialogTitle">@dialog.Title</span>
                <button id="dialogClose" class="dialog-close" @onclick="CloseAsync">X</button>
            </div>
            <div id="@AccessibilityPrimitiveBoundary.BuildDialogDescriptionId(dialog.Id)" class="dialog-body">
                @if (!string.IsNullOrWhiteSpace(dialog.Message))
                {
                    <p class="dialog-note">@dialog.Message</p>
                }
                @foreach (DesktopDialogField field in dialog.Fields)
                {
                    <label class="dialog-field @(string.Equals(field.InputType, "checkbox", StringComparison.Ordinal) ? "dialog-field--checkbox" : string.Empty) @(BuildDialogFieldLayoutClass(field)) @(BuildDialogFieldVisualClass(field))">
                        @if (string.Equals(field.InputType, "checkbox", StringComparison.Ordinal))
                        {
                            <input type="checkbox"
                                   checked="@IsDialogCheckboxChecked(field)"
                                   disabled="@field.IsReadOnly"
                                   @onchange="e => OnDialogCheckboxChangedAsync(field, e.Value)" />
                            <span class="dialog-label">@field.Label</span>
                        }
                        else if (field.IsMultiline)
                        {
                            <span class="dialog-label">@field.Label</span>
                            @if (field.IsReadOnly && !string.Equals(field.VisualKind, DesktopDialogFieldVisualKinds.Default, StringComparison.Ordinal))
                            {
                                <div class="@BuildDialogVisualClass(field)">
                                    @if (string.Equals(field.VisualKind, DesktopDialogFieldVisualKinds.Tabs, StringComparison.Ordinal))
                                    {
                                        @foreach (string item in SplitVisualLines(field.Value))
                                        {
                                            <span class="dialog-tab-chip">@item</span>
                                        }
                                    }
                                    else if (string.Equals(field.VisualKind, DesktopDialogFieldVisualKinds.Image, StringComparison.Ordinal))
                                    {
                                        <div class="dialog-image-placeholder">
                                            <div class="dialog-image-box">@SplitVisualLines(field.Value).FirstOrDefault() ?? "Mugshot Preview"</div>
                                            @foreach (string item in SplitVisualLines(field.Value).Skip(1))
                                            {
                                                <div>@item</div>
                                            }
                                        </div>
                                    }
                                    else if (string.Equals(field.VisualKind, DesktopDialogFieldVisualKinds.Grid, StringComparison.Ordinal))
                                    {
                                        <div class="dialog-grid">
                                            @foreach ((string key, string value) in SplitGridRows(field.Value))
                                            {
                                                <div class="dialog-grid-row">
                                                    <span class="dialog-grid-key">@key</span>
                                                    <span class="dialog-grid-value">@value</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else if (string.Equals(field.VisualKind, DesktopDialogFieldVisualKinds.Snippet, StringComparison.Ordinal))
                                    {
                                        <div class="dialog-snippet">@field.Value</div>
                                    }
                                    else
                                    {
                                        <pre class="dialog-visual-pre">@field.Value</pre>
                                    }
                                </div>
                            }
                            else
                            {
                                <textarea class="@BuildDialogInputClass(field)"
                                          value="@field.Value"
                                          placeholder="@field.Placeholder"
                                          readonly="@field.IsReadOnly"
                                          @oninput="e => OnDialogFieldInputAsync(field, e.Value?.ToString())"></textarea>
                            }
                        }
                        else
                        {
                            <span class="dialog-label">@field.Label</span>
                            <input class="@BuildDialogInputClass(field)"
                                   type="@field.InputType"
                                   value="@field.Value"
                                   placeholder="@field.Placeholder"
                                   readonly="@field.IsReadOnly"
                                   @oninput="e => OnDialogFieldInputAsync(field, e.Value?.ToString())" />
                        }
                    </label>
                }
            </div>
            <div id="dialogFooter" class="dialog-footer">
                @foreach (DesktopDialogAction action in dialog.Actions)
                {
                    <button class="action-btn @(action.IsPrimary ? "primary" : string.Empty)"
                            @onclick="() => ExecuteDialogActionAsync(action.Id)">
                        @action.Label
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public DesktopDialogState? Dialog { get; set; }

    [Parameter]
    public EventCallback CloseRequested { get; set; }

    [Parameter]
    public EventCallback<string> ExecuteDialogActionRequested { get; set; }

    [Parameter]
    public EventCallback<DialogFieldInputChange> FieldInputRequested { get; set; }

    [Parameter]
    public EventCallback<DialogFieldCheckboxChange> FieldCheckboxRequested { get; set; }

    private ElementReference _dialogRoot;
    private string? _focusedDialogId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Dialog is null || string.Equals(_focusedDialogId, Dialog.Id, StringComparison.Ordinal))
            return;

        _focusedDialogId = Dialog.Id;
        await _dialogRoot.FocusAsync();
    }

    private Task CloseAsync()
    {
        return CloseRequested.InvokeAsync();
    }

    private Task ExecuteDialogActionAsync(string actionId)
    {
        return ExecuteDialogActionRequested.InvokeAsync(actionId);
    }

    private Task OnDialogFieldInputAsync(DesktopDialogField field, string? value)
    {
        if (field.IsReadOnly)
            return Task.CompletedTask;

        return FieldInputRequested.InvokeAsync(new DialogFieldInputChange(field.Id, value));
    }

    private Task OnDialogCheckboxChangedAsync(DesktopDialogField field, object? value)
    {
        if (field.IsReadOnly)
            return Task.CompletedTask;

        bool parsed = value is bool direct
            ? direct
            : bool.TryParse(value?.ToString(), out bool parsedBool) && parsedBool;
        return FieldCheckboxRequested.InvokeAsync(new DialogFieldCheckboxChange(field.Id, parsed));
    }

    private static bool IsDialogCheckboxChecked(DesktopDialogField field)
    {
        if (bool.TryParse(field.Value, out bool value))
            return value;

        return string.Equals(field.Value, "1", StringComparison.Ordinal)
            || string.Equals(field.Value, "on", StringComparison.OrdinalIgnoreCase)
            || string.Equals(field.Value, "yes", StringComparison.OrdinalIgnoreCase);
    }

    private static string BuildDialogFieldLayoutClass(DesktopDialogField field)
    {
        return field.LayoutSlot switch
        {
            DesktopDialogFieldLayoutSlots.Left => "dialog-field--left",
            DesktopDialogFieldLayoutSlots.Right => "dialog-field--right",
            _ => "dialog-field--full"
        };
    }

    private static string BuildDialogFieldVisualClass(DesktopDialogField field)
    {
        return field.VisualKind switch
        {
            DesktopDialogFieldVisualKinds.List => "dialog-field--list",
            DesktopDialogFieldVisualKinds.Tree => "dialog-field--tree",
            DesktopDialogFieldVisualKinds.Grid => "dialog-field--grid",
            DesktopDialogFieldVisualKinds.Detail => "dialog-field--detail",
            DesktopDialogFieldVisualKinds.Summary => "dialog-field--summary",
            DesktopDialogFieldVisualKinds.Snippet => "dialog-field--snippet",
            DesktopDialogFieldVisualKinds.Tabs => "dialog-field--tabs",
            DesktopDialogFieldVisualKinds.Image => "dialog-field--image",
            _ => string.Empty
        };
    }

    private static string BuildDialogInputClass(DesktopDialogField field)
    {
        return field.VisualKind switch
        {
            DesktopDialogFieldVisualKinds.List => "dialog-input dialog-input--list",
            DesktopDialogFieldVisualKinds.Tree => "dialog-input dialog-input--tree",
            DesktopDialogFieldVisualKinds.Grid => "dialog-input dialog-input--grid",
            DesktopDialogFieldVisualKinds.Detail => "dialog-input dialog-input--detail",
            DesktopDialogFieldVisualKinds.Summary => "dialog-input dialog-input--summary",
            DesktopDialogFieldVisualKinds.Snippet => "dialog-input dialog-input--snippet",
            _ => "dialog-input"
        };
    }

    private static string BuildDialogVisualClass(DesktopDialogField field)
    {
        return field.VisualKind switch
        {
            DesktopDialogFieldVisualKinds.Tabs => "dialog-visual dialog-visual--tabs",
            DesktopDialogFieldVisualKinds.Image => "dialog-visual dialog-visual--image",
            DesktopDialogFieldVisualKinds.Tree => "dialog-visual dialog-visual--tree",
            DesktopDialogFieldVisualKinds.Grid => "dialog-visual dialog-visual--grid",
            DesktopDialogFieldVisualKinds.Snippet => "dialog-visual dialog-visual--snippet",
            _ => "dialog-visual"
        };
    }

    private static IReadOnlyList<string> SplitVisualLines(string value)
    {
        return value.Split(Environment.NewLine, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    }

    private static IReadOnlyList<(string Key, string Value)> SplitGridRows(string value)
    {
        return value
            .Split(Environment.NewLine, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(line =>
            {
                string[] parts = line.Split('|', 2, StringSplitOptions.TrimEntries);
                return parts.Length == 2 ? (parts[0], parts[1]) : (line, string.Empty);
            })
            .ToArray();
    }
}
