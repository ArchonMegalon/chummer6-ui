@namespace Chummer.Blazor.Components.Shell
@using Chummer.Contracts.Presentation
@using Chummer.Presentation.UiKit

<div class="tool-strip">
    @foreach (AppCommandDefinition command in Commands)
    {
        bool enabled = IsCommandEnabled(command);
        <button class="tool-btn @(string.Equals(LastCommandId, command.Id, StringComparison.Ordinal) ? "selected" : string.Empty)"
                title="@ShellChromeBoundary.FormatCommandLabel(command.Id)"
                disabled="@(!enabled || IsBusy)"
                @onclick="() => ExecuteCommandAsync(command.Id)">
            @FormatToolStripLabel(command.Id)
        </button>
    }
</div>

@code {
    [Parameter]
    public IReadOnlyList<AppCommandDefinition> Commands { get; set; } = [];

    [Parameter]
    public string? LastCommandId { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public Func<AppCommandDefinition, bool> IsCommandEnabled { get; set; } = _ => false;

    [Parameter]
    public EventCallback<string> ExecuteCommandRequested { get; set; }

    private Task ExecuteCommandAsync(string commandId)
    {
        return ExecuteCommandRequested.InvokeAsync(commandId);
    }

    private static string FormatToolStripLabel(string commandId)
        => commandId switch
        {
            "new_character" => "New",
            "open_character" => "Open",
            "save_character" => "Save",
            "save_character_as" => "Save As",
            "print_character" => "Print",
            "copy" => "Copy",
            "paste" => "Paste",
            "close_window" => "Close",
            "close_all" => "Close All",
            "update" => "Update",
            "global_settings" => "Options",
            "report_bug" => "Bug",
            _ => ShellChromeBoundary.FormatCommandLabel(commandId)
        };
}
