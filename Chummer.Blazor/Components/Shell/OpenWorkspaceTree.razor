@namespace Chummer.Blazor.Components.Shell
@using Chummer.Contracts.Workspaces
@using Chummer.Contracts.Rulesets
@using Chummer.Presentation.Overview
@using Chummer.Presentation.Rulesets

<section class="panel navigator" aria-label="@BuildOpenWorkspacesHeading()">
    <h2 class="visually-hidden">@BuildOpenWorkspacesHeading()</h2>
    @if (OpenWorkspaces.Count == 0)
    {
        <p class="hint">No open workspaces.</p>
    }
    else
    {
        <div class="virtual-list navigator-list" data-testid="open-workspace-tree">
            @* <Virtualize Items="@OpenWorkspaces" ItemsTagName="ul" ItemTagName="li"> *@
            <Virtualize Items="@(OpenWorkspaces.ToArray())"
                        Context="workspace"
                        ItemSize="40">
                @{
                    bool isActive = string.Equals(ActiveWorkspaceId?.Value, workspace.Id.Value, StringComparison.Ordinal);
                    string workspaceLabel = RulesetUiDirectiveCatalog.BuildWorkspaceNavigatorLabel(
                        workspace.RulesetId,
                        workspace.Name,
                        workspace.Alias,
                        workspace.HasSavedWorkspace);
                }
                <div class="navigator-row">
                    <button class="command-button @(isActive ? "selected" : string.Empty)"
                            title="@workspace.Id.Value"
                            disabled="@IsBusy"
                            @onclick="() => OpenWorkspaceAsync(workspace.Id.Value)">
                        <span>@workspaceLabel</span>
                    </button>
                    <button class="mini-btn compact-close"
                            aria-label="Close workspace"
                            title="Close workspace"
                            disabled="@IsBusy"
                            @onclick="() => CloseWorkspaceAsync(workspace.Id.Value)">
                        ×
                    </button>
                </div>
            </Virtualize>
        </div>
    }
</section>

@code {
    [Parameter]
    public IReadOnlyList<OpenWorkspaceState> OpenWorkspaces { get; set; } = [];

    [Parameter]
    public CharacterWorkspaceId? ActiveWorkspaceId { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback<string> OpenWorkspaceRequested { get; set; }

    [Parameter]
    public EventCallback<string> CloseWorkspaceRequested { get; set; }

    private Task OpenWorkspaceAsync(string workspaceId)
    {
        return OpenWorkspaceRequested.InvokeAsync(workspaceId);
    }

    private Task CloseWorkspaceAsync(string workspaceId)
    {
        return CloseWorkspaceRequested.InvokeAsync(workspaceId);
    }

    private string BuildOpenWorkspacesHeading()
    {
        string? activeRulesetId = OpenWorkspaces
            .FirstOrDefault(workspace => string.Equals(workspace.Id.Value, ActiveWorkspaceId?.Value, StringComparison.Ordinal))
            ?.RulesetId;
        return RulesetUiDirectiveCatalog.BuildOpenWorkspacesHeading(
            RulesetDefaults.NormalizeOptional(activeRulesetId)
            ?? RulesetDefaults.NormalizeOptional(OpenWorkspaces.FirstOrDefault()?.RulesetId));
    }
}
