@namespace Chummer.Blazor.Components.Shell
@using Chummer.Presentation.Rulesets

<section class="panel results">
    <h2>@BuildResultHeading()</h2>
    <p class="hint">@BuildResultPostureHint()</p>
    <p class="note">@(State.Notice ?? BuildResultReadyNotice())</p>
    @if (State.LatestPortabilityActivity is { } portability)
    {
        <p class="hint"><strong>@portability.Title:</strong> @portability.Receipt.ReceiptSummary</p>
        <p class="hint"><strong>Context:</strong> @portability.Receipt.ContextSummary</p>
        <p class="hint"><strong>Next safe action:</strong> @portability.Receipt.NextSafeAction</p>
        <p class="hint"><strong>Exchange modes:</strong> @string.Join(", ", portability.Receipt.SupportedExchangeModes)</p>
        @if (portability.Receipt.Notes.Count > 0)
        {
            <p class="hint"><strong>Notes:</strong> @string.Join(" ", portability.Receipt.Notes.Select(note => note.Summary).Take(2))</p>
        }
    }
    <p class="hint">UI: @State.Preferences.UiScalePercent% / @State.Preferences.Theme / @State.Preferences.Language</p>
    <p class="hint">Character: @State.Preferences.CharacterPriority, Ratio @State.Preferences.KarmaNuyenRatio, House Rules @(State.Preferences.HouseRulesEnabled ? "On" : "Off")</p>
    @if (!string.IsNullOrWhiteSpace(State.Error))
    {
        <p class="error">Error: @State.Error</p>
    }
</section>

@code {
    [Parameter]
    public string? RulesetId { get; set; }

    [Parameter]
    public CharacterOverviewState State { get; set; } = CharacterOverviewState.Empty;

    private string BuildResultHeading()
        => RulesetUiDirectiveCatalog.BuildResultHeading(RulesetId);

    private string BuildResultPostureHint()
        => RulesetUiDirectiveCatalog.BuildResultPostureHint(RulesetId);

    private string BuildResultReadyNotice()
        => RulesetUiDirectiveCatalog.BuildResultReadyNotice(RulesetId);
}
