@page "/"
@using Chummer.Contracts.Characters
@using Chummer.Campaign.Contracts
@using Chummer.Contracts.Content
@using Chummer.Contracts.Journal
@using Chummer.Contracts.Presentation
@using Chummer.Contracts.Rulesets
@using Chummer.Presentation.Explain
@using Chummer.Presentation.Overview

<main class="page">
    <section class="panel-grid">
        <ExplainTracePanel Trace="_sampleExplainTrace" Chrome="_sampleExplainChrome" />
        <BuildLabPanel Projection="_buildLabProjection" />
        <BuildLabHandoffPanel Projection="_buildLabHandoff" />
        <RulesNavigatorPanel Projection="_rulesNavigator" />
        <RuntimeInspectorPanel Projection="_runtimeInspector" />
        <CampaignJournalPanel Projection="_journalPanel" />
        <ContactNetworkPanel Graph="_contactGraph" />
        <NpcPersonaStudioPanel Projection="_npcPersonaStudio" />
        <CreatorPublicationPanel Publication="_creatorPublication" />

        <GmBoardFeed InterruptionBudget="_interruptionBudget"
                     CurrentSessionContext="_currentSessionContext"
                     SessionContexts="SessionContexts"
                     SessionContextChanged="OnSessionContextChanged"
                     AutonomyLevel="_autonomyLevel"
                     AutonomyLevelChanged="OnAutonomyLevelChanged"
                     InterruptionBudgetChanged="OnBudgetChanged"
                     MuteRequested="OnMuteRequested"
                     MutedUntilLabel="_mutedUntilLabel"
                     Cards="VisibleGmCards"
                     QuickActionRequested="OnCardQuickAction"
                     PinRequested="OnCardPinned"
                     DismissRequested="OnCardDismissed"
                     SnoozeRequested="OnCardSnoozed" />

        <GeneratedAssetReviewPanel Assets="_assets"
                                   SelectedAssetId="_selectedAssetId"
                                   SelectedAssetChanged="OnSelectedAssetChanged"
                                   ActionRequested="OnAssetActionRequested" />
    </section>
</main>

