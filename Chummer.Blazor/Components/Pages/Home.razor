    protected override void OnInitialized()
    {
        _contactGraph = ContactRelationshipGraphProjector.FromContacts(_contacts);
    }

    private IReadOnlyList<GmBoardFeed.GmBoardCard> VisibleGmCards => _gmCards
        .Where(card => card.IsPinned || IsCardVisibleAtAutonomy(card.MinimumAutonomy, _autonomyLevel))
        .OrderByDescending(card => card.IsPinned)
        .ThenBy(card => card.IsSnoozed)
        .ThenBy(card => card.Timestamp, StringComparer.Ordinal)
        .ToArray();

    private void OnBudgetChanged(int value) => _interruptionBudget = value;

    private void OnAutonomyLevelChanged(string level) => _autonomyLevel = level;

    private void OnSessionContextChanged(string context)
    {
        _currentSessionContext = context;
        _assets = _assets
            .Select(asset => ApplyDispatchInvalidation(asset, context))
            .ToArray();
    }

    private void OnMuteRequested(int minutes)
    {
        _interruptionBudget = Math.Max(0, _interruptionBudget - Math.Min(minutes, 25));
        _mutedUntilLabel = minutes <= 0
            ? null
            : $"Spider muted for {minutes} min";
        _gmCards = _gmCards
            .Select(card => card with
            {
                IsPrimaryActionMuted = card.IsSnoozed
            })
            .ToArray();
    }

    private void OnCardPinned(string cardId)
    {
        if (_gmCards.All(card => card.Id != cardId))
        {
            return;
        }

        _gmCards = _gmCards
            .Select(card => card.Id == cardId
                ? card with { IsPinned = !card.IsPinned }
                : card)
            .OrderByDescending(card => card.IsPinned)
            .ToArray();
    }

    private void OnCardDismissed(string cardId)
    {
        _gmCards = _gmCards.Where(card => card.Id != cardId).ToArray();
    }

    private void OnCardSnoozed(string cardId)
    {
        _interruptionBudget = Math.Min(100, _interruptionBudget + 5);
        _gmCards = _gmCards
            .Select(card => card.Id == cardId
                ? card with
                {
                    IsSnoozed = !card.IsSnoozed,
                    SnoozedUntilLabel = card.IsSnoozed ? null : "next context refresh",
                    IsPrimaryActionMuted = !card.IsSnoozed
                }
                : card)
            .ToArray();
    }

    private void OnCardQuickAction(GmBoardFeed.GmBoardQuickActionRequest request)
    {
        _gmCards = _gmCards
            .Select(card => card.Id == request.CardId
                ? card with
                {
                    Summary = request.ActionId.StartsWith("refresh-", StringComparison.Ordinal)
                        ? $"Refreshed for {_currentSessionContext}. {card.Summary}"
                        : $"Action executed: {request.ActionId}. {card.Summary}",
                    Expiry = request.ActionId.StartsWith("refresh-", StringComparison.Ordinal)
                        ? $"Valid in {_currentSessionContext}"
                        : "Executed just now",
                    ContextSnapshot = _currentSessionContext,
                    IsSnoozed = false,
                    SnoozedUntilLabel = null,
                    IsPrimaryActionMuted = false
                }
                : card)
            .ToArray();
    }

    private static bool IsCardVisibleAtAutonomy(string minimumLevel, string currentLevel)
        => GetAutonomyRank(currentLevel) >= GetAutonomyRank(minimumLevel);

    private static int GetAutonomyRank(string level)
    {
        return level.ToLowerInvariant() switch
        {
            "off" => 0,
            "low" => 1,
            "tactical" => 2,
            "narrative" => 3,
            "high" => 4,
            _ => 2
        };
    }

    private void OnSelectedAssetChanged(string assetId)
    {
        _selectedAssetId = assetId;
    }

    private void OnAssetActionRequested(GeneratedAssetActionRequest request)
    {
        _selectedAssetId = request.AssetId;
        _assets = _assets
            .Select(asset => ApplyAssetAction(asset, request, _currentSessionContext))
            .ToArray();
    }

    private static GeneratedAssetProjection ApplyAssetAction(
        GeneratedAssetProjection asset,
        GeneratedAssetActionRequest request,
        string currentSessionContext)
    {
        if (!string.Equals(asset.AssetId, request.AssetId, StringComparison.Ordinal))
        {
            return request.ActionKind is GeneratedAssetActionKinds.Approve or GeneratedAssetActionKindMarkCanonical
                ? asset with { IsCanonical = false }
                : asset;
        }

        return request.ActionKind switch
        {
            GeneratedAssetActionKinds.Attach => asset with
            {
                ReviewState = $"attached:{request.TargetId}",
                Metadata = ReplaceMetadataValue(asset.Metadata, "share", "Attach target", $"Attached to {request.TargetId}.")
            },
            GeneratedAssetActionKindDispatch => asset with
            {
                ReviewState = "dispatched",
                Metadata = ReplaceMetadataValues(
                    asset.Metadata,
                    ("shadowfeedDispatchReceipt", "Dispatch Receipt", "dispatch:queued"),
                    ("shadowfeedReviewer", "Reviewer", "pending-review"),
                    ("dispatchContext", "Dispatch Context", currentSessionContext))
            },
            GeneratedAssetActionKindReview => asset with
            {
                ReviewState = "review:queued",
                Metadata = ReplaceMetadataValues(
                    asset.Metadata,
                    ("shadowfeedReviewQueue", "Review Queue", "queued"),
                    ("shadowfeedReviewer", "Reviewer", "coach-operator"),
                    ("dispatchContext", "Dispatch Context", currentSessionContext))
            },
            GeneratedAssetActionKindRefreshDispatch => asset with
            {
                ReviewState = "dispatched",
                Metadata = ReplaceMetadataValues(
                    asset.Metadata,
                    ("shadowfeedDispatchReceipt", "Dispatch Receipt", "dispatch:refreshed"),
                    ("dispatchContext", "Dispatch Context", currentSessionContext))
            },
            GeneratedAssetActionKinds.Approve => asset with
            {
                ReviewState = "approved",
                IsCanonical = true,
                Metadata = ReplaceMetadataValue(asset.Metadata, "canonicalAssetId", "Canonical Asset", asset.AssetId)
            },
            GeneratedAssetActionKindMarkCanonical => asset with
            {
                ReviewState = "canonical:selected",
                IsCanonical = true,
                Metadata = ReplaceMetadataValue(asset.Metadata, "canonicalAssetId", "Canonical Asset", asset.AssetId)
            },
            GeneratedAssetActionKinds.Archive => asset with
            {
                ReviewState = "archived",
                IsCanonical = false
            },
            _ => asset
        };
    }

    private static GeneratedAssetProjection ApplyDispatchInvalidation(GeneratedAssetProjection asset, string context)
    {
        string? invalidates = GetMetadataValue(asset.Metadata, "invalidatesOnContextShift");
        if (!string.Equals(invalidates, "true", StringComparison.OrdinalIgnoreCase))
        {
            return asset;
        }

        string? dispatchContext = GetMetadataValue(asset.Metadata, "dispatchContext");
        if (string.IsNullOrWhiteSpace(dispatchContext)
            || string.Equals(dispatchContext, context, StringComparison.Ordinal))
        {
            return asset;
        }

        return asset with
        {
            ReviewState = $"stale:{context}",
            Metadata = ReplaceMetadataValue(asset.Metadata, "shadowfeedDispatchReceipt", "Dispatch Receipt", $"invalidated:{context}")
        };
    }

    private static string? GetMetadataValue(IReadOnlyList<GeneratedAssetMetadataField>? metadata, string fieldId)
        => metadata?.FirstOrDefault(field => string.Equals(field.FieldId, fieldId, StringComparison.Ordinal))?.Value;

    private static IReadOnlyList<GeneratedAssetMetadataField> ReplaceMetadataValue(
        IReadOnlyList<GeneratedAssetMetadataField>? metadata,
        string fieldId,
        string fallbackLabel,
        string value)
    {
        if (metadata is null || metadata.Count == 0)
        {
            return [new GeneratedAssetMetadataField(fieldId, fallbackLabel, value)];
        }

        bool matched = false;
        List<GeneratedAssetMetadataField> updated = metadata
            .Select(field =>
            {
                if (!string.Equals(field.FieldId, fieldId, StringComparison.Ordinal))
                {
                    return field;
                }

                matched = true;
                return field with { Value = value };
            })
            .ToList();

        if (!matched)
        {
            updated.Add(new GeneratedAssetMetadataField(fieldId, fallbackLabel, value));
        }

        return updated;
    }

    private static IReadOnlyList<GeneratedAssetMetadataField> ReplaceMetadataValues(
        IReadOnlyList<GeneratedAssetMetadataField>? metadata,
        params (string FieldId, string Label, string Value)[] updates)
    {
        IReadOnlyList<GeneratedAssetMetadataField> current = metadata ?? [];
        foreach ((string fieldId, string label, string value) in updates)
        {
            current = ReplaceMetadataValue(current, fieldId, label, value);
        }

        return current;
    }
}
