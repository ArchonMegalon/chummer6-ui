<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chummer.Avalonia.Controls.WorkspaceStripControl">
  <StackPanel Spacing="3" VerticalAlignment="Center">
    <TextBlock Classes="shell-kicker" Text="Active Workspace" />
    <TextBlock x:Name="WorkspaceText"
               Classes="shell-section-title"
               VerticalAlignment="Center"
               Text="Workspace: none"
               TextWrapping="Wrap" />
    <Border x:Name="QuickStartContainer"
            Classes="shell-card subtle"
            Padding="8,6"
            IsVisible="False">
      <StackPanel Spacing="4">
        <TextBlock Classes="shell-kicker" Text="Quick Start" />
        <TextBlock x:Name="QuickStartCaptionText"
                   Text="Load the bundled demo runner to open a real workbench immediately."
                   TextWrapping="Wrap" />
        <Button x:Name="LoadDemoRunnerQuickActionButton"
                Classes="shell-action quiet"
                Content="Load Demo Runner"
                HorizontalAlignment="Left"
                Click="LoadDemoRunnerQuickActionButton_OnClick" />
      </StackPanel>
    </Border>
    <TextBlock x:Name="WorkspaceCaptionText"
               Classes="shell-caption"
               Text="Ruleset, tabs, and save posture stay visible while you move through dense builder sections." />
  </StackPanel>
</UserControl>
