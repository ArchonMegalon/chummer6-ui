<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chummer.Avalonia.Controls.WorkspaceStripControl">
  <Grid RowDefinitions="Auto,Auto" RowSpacing="2" VerticalAlignment="Center">
    <TextBlock x:Name="WorkspaceText"
               Grid.Row="0"
               Classes="shell-caption"
               VerticalAlignment="Center"
               Text="Workspace: none"
               TextTrimming="CharacterEllipsis" />
    <StackPanel x:Name="QuickStartContainer"
                Grid.Row="1"
                Orientation="Horizontal"
                Spacing="4"
                IsVisible="False">
      <TextBlock x:Name="QuickStartCaptionText"
                 Classes="shell-caption"
                 VerticalAlignment="Center"
                 Text="Start:" />
      <Button x:Name="LoadDemoRunnerQuickActionButton"
              Classes="shell-action quiet"
              Content="Demo"
              Click="LoadDemoRunnerQuickActionButton_OnClick" />
    </StackPanel>
    <TextBlock x:Name="WorkspaceCaptionText"
               IsVisible="False"
               Text="Ruleset, tabs, and save posture stay visible while you move through dense builder sections." />
  </Grid>
</UserControl>
