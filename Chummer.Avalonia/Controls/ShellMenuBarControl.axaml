<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chummer.Avalonia.Controls.ShellMenuBarControl">
  <Menu x:Name="MenuBarPanel"
        Classes="classic-menu">
    <MenuItem x:Name="FileMenuButton"
              Header="File"
              Tag="file"
              Click="RootMenuItem_OnClick"
              PointerPressed="RootMenuItem_OnPointerPressed"
              SubmenuOpened="RootMenuItem_OnSubmenuOpened" />
    <MenuItem x:Name="ToolsMenuButton"
              Header="Tools"
              Tag="tools"
              Click="RootMenuItem_OnClick"
              PointerPressed="RootMenuItem_OnPointerPressed"
              SubmenuOpened="RootMenuItem_OnSubmenuOpened" />
    <MenuItem x:Name="WindowsMenuButton"
              Header="Windows"
              Tag="windows"
              Click="RootMenuItem_OnClick"
              PointerPressed="RootMenuItem_OnPointerPressed"
              SubmenuOpened="RootMenuItem_OnSubmenuOpened" />
    <MenuItem x:Name="HelpMenuButton"
              Header="Help"
              Tag="help"
              Click="RootMenuItem_OnClick"
              PointerPressed="RootMenuItem_OnPointerPressed"
              SubmenuOpened="RootMenuItem_OnSubmenuOpened" />
  </Menu>
</UserControl>
