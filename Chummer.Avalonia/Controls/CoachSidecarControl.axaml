<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chummer.Avalonia.Controls.CoachSidecarControl">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="12">
      <Border Classes="shell-card subtle">
        <StackPanel Spacing="6">
          <TextBlock Classes="shell-kicker" Text="Coach Sidecar" />
          <TextBlock x:Name="CoachStatusText" Classes="shell-section-title" Text="Status: unloaded" TextWrapping="Wrap" />
          <TextBlock x:Name="CoachPromptPolicyText" Classes="shell-caption" Text="Prompt Policy: n/a" TextWrapping="Wrap" />
          <TextBlock x:Name="CoachBudgetText" Classes="shell-caption" Text="Coach Budget: n/a" TextWrapping="Wrap" />
          <TextBlock x:Name="CoachWorkspaceText" Classes="shell-caption" Text="Workspace: n/a" TextWrapping="Wrap" />
          <TextBlock x:Name="CoachRuntimeText" Classes="shell-caption" Text="Runtime: n/a" TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Classes="shell-card">
        <StackPanel Spacing="8">
          <TextBlock Classes="shell-section-title" Text="Coach Launch" />
          <TextBox x:Name="CoachLaunchUriTextBox" IsReadOnly="True" Watermark="/coach/" />
          <Button x:Name="CopyCoachLaunchButton"
                  Classes="shell-action"
                  Content="Copy Coach Link"
                  Click="CopyCoachLaunchButton_OnClick"
                  HorizontalAlignment="Left" />
          <TextBlock x:Name="CoachLaunchStatusText"
                     Classes="shell-caption"
                     Text="Launch link unavailable."
                     TextWrapping="Wrap" />
          <TextBlock x:Name="CoachErrorText"
                     Classes="shell-caption"
                     Text="(none)"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Classes="shell-card">
        <StackPanel Spacing="8">
          <TextBlock Classes="shell-section-title" Text="Provider Health" />
          <ListBox x:Name="ProviderHealthList">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>

      <Border Classes="shell-card">
        <StackPanel Spacing="8">
          <TextBlock Classes="shell-section-title" Text="Recent Coach Guidance" />
          <ListBox x:Name="AuditList">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
