<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Chummer.Avalonia.Controls"
             x:Class="Chummer.Avalonia.Controls.SectionHostControl">
  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="1">
    <Border Grid.Row="0"
            x:Name="LoadedRunnerTabStripBorder"
            Classes="shell-panel subtle"
            Padding="1,0"
            IsVisible="False">
      <TabStrip x:Name="LoadedRunnerTabStrip"
                Classes="classic-tabs"
                SelectionChanged="LoadedRunnerTabStrip_OnSelectionChanged">
        <TabStrip.ItemTemplate>
          <DataTemplate x:DataType="controls:NavigatorTabItem">
            <TextBlock Text="{Binding Label}" Classes="shell-tab-label" />
          </DataTemplate>
        </TabStrip.ItemTemplate>
      </TabStrip>
    </Border>

    <Border Grid.Row="1"
            x:Name="SectionActionTabStripBorder"
            Classes="shell-panel subtle"
            Padding="1,0"
            IsVisible="False">
      <TabStrip x:Name="SectionActionTabStrip"
                Classes="classic-tabs"
                SelectionChanged="SectionActionTabStrip_OnSelectionChanged">
        <TabStrip.ItemTemplate>
          <DataTemplate x:DataType="controls:NavigatorSectionActionItem">
            <TextBlock Text="{Binding Label}" Classes="shell-tab-label" />
          </DataTemplate>
        </TabStrip.ItemTemplate>
      </TabStrip>
    </Border>

    <Border Grid.Row="2" x:Name="NoticeBorder" Classes="shell-panel subtle" Padding="2,1" IsVisible="False">
      <TextBlock x:Name="NoticeText"
                 Classes="shell-caption"
                 Text="Notice: Ready."
                 TextTrimming="CharacterEllipsis" />
    </Border>

    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
      <Border Padding="0">
      <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="2">
        <Border Grid.Row="0"
                x:Name="SectionContextBorder"
                Classes="shell-panel subtle"
                IsVisible="False"
                Padding="3,2">
          <StackPanel Spacing="1">
            <TextBlock x:Name="SectionContextTitleText"
                       Classes="shell-section-title"
                       Text="Section" />
            <TextBlock x:Name="SectionContextSummaryText"
                       Classes="shell-caption"
                       Text="Section summary"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </Border>
        <Border Grid.Row="1"
                x:Name="ClassicCharacterSheetBorder"
                Classes="shell-panel"
                IsVisible="False"
                Padding="3,2">
          <StackPanel Spacing="4">
            <TextBlock x:Name="ClassicCharacterSummaryTitle"
                       Text="Runner Summary"
                       Classes="shell-section-title" />
            <WrapPanel x:Name="ClassicCharacterFactsPanel"
                       Orientation="Horizontal"
                       ItemHeight="32" />
            <WrapPanel x:Name="ClassicAttributeFactsPanel"
                       Orientation="Horizontal"
                       ItemHeight="28" />
          </StackPanel>
        </Border>
        <Border Grid.Row="2"
                x:Name="SectionRowsBorder"
                Classes="shell-panel"
                Padding="1,0">
          <ListBox x:Name="SectionRowsList"
                   Height="176"
                   BorderThickness="0"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="92,*" ColumnSpacing="6" Margin="0,0">
                  <TextBlock Grid.Column="0"
                             Text="{Binding DisplayPath}"
                             Classes="shell-caption"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding DisplayValue}"
                             TextWrapping="NoWrap"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <VirtualizingStackPanel />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
          </ListBox>
        </Border>
        <Expander Grid.Row="3"
                  x:Name="SectionPayloadExpander"
                  Header="Section Payload"
                  Height="0"
                  MinHeight="0"
                  MaxHeight="0"
                  Opacity="0"
                  IsHitTestVisible="False"
                  ClipToBounds="True"
                  IsExpanded="False" />
        <Expander Grid.Row="3"
                  x:Name="SectionReviewExpander"
                  Header="Section Review"
                  IsExpanded="True"
                  IsVisible="False">
          <TextBox x:Name="SectionPreviewBox"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   IsReadOnly="True"
                   MinHeight="120" />
        </Expander>
        <Border Grid.Row="4"
                x:Name="SectionQuickActionsBorder"
                Classes="shell-panel"
                Padding="1,0"
                IsVisible="False">
          <StackPanel x:Name="SectionQuickActionsHost"
                      Orientation="Horizontal"
                      Spacing="4" />
        </Border>
      </Grid>
      </Border>
    </ScrollViewer>

    <Border Grid.Row="4" x:Name="RawXmlImportBorder" Classes="shell-panel subtle" Padding="3" IsVisible="False">
      <Expander Header="Raw XML Import" IsExpanded="False">
        <StackPanel Spacing="2" Margin="0,4,0,0">
          <TextBox x:Name="XmlInputBox"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Height="64"
                   Watermark="Paste raw XML when you need a direct import or diagnostics." />
        </StackPanel>
      </Expander>
    </Border>
  </Grid>
</UserControl>
