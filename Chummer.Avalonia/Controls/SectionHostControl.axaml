<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chummer.Avalonia.Controls.SectionHostControl">
  <Grid RowDefinitions="Auto,*,Auto" RowSpacing="2">
    <Border Grid.Row="0" Classes="shell-panel subtle" Padding="3,1">
      <TextBlock x:Name="NoticeText"
                 Classes="shell-caption"
                 Text="Notice: Ready."
                 TextTrimming="CharacterEllipsis" />
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <Border Padding="2">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto" RowSpacing="4">
        <TextBlock Grid.Row="0" Text="Section Workbench" Classes="shell-section-title" IsVisible="False" />
        <Border Grid.Row="1"
                x:Name="SectionQuickActionsBorder"
                Classes="shell-panel subtle"
                IsVisible="False"
                Padding="3">
          <StackPanel Spacing="2">
            <WrapPanel x:Name="SectionQuickActionsPanel"
                       Orientation="Horizontal"
                       ItemHeight="24" />
          </StackPanel>
        </Border>
        <Border Grid.Row="2"
                x:Name="BuildLabBorder"
                Classes="shell-panel"
                IsVisible="False"
                Padding="4"
                BorderThickness="1"
                Background="{DynamicResource ChummerShellSurfaceBrush}"
                BorderBrush="{DynamicResource ChummerShellBorderBrush}">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4">
            <TextBlock x:Name="BuildLabSummaryText"
                       Text="Build Lab intake"
                       FontWeight="Bold"
                       TextWrapping="Wrap" />
            <ListBox Grid.Row="1" x:Name="BuildLabFieldsList" Height="132">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
            <ListBox Grid.Row="2" x:Name="BuildLabConstraintsList" Height="72">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
            <TextBox Grid.Row="3"
                     x:Name="BuildLabProvenanceBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True" />
            <ListBox Grid.Row="4" x:Name="BuildLabVariantsList" Height="128">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
            <TextBox Grid.Row="5"
                     x:Name="BuildLabCoverageBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True" />
            <TextBox Grid.Row="6"
                     x:Name="BuildLabTimelinesBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True" />
            <TextBox Grid.Row="7"
                     x:Name="BuildLabExportPayloadsBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True" />
            <ListBox Grid.Row="8" x:Name="BuildLabExportTargetsList" Height="96">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
            <ListBox Grid.Row="9" x:Name="BuildLabActionsList" Height="56">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
          </Grid>
        </Border>
        <Border Grid.Row="3"
                x:Name="BrowseWorkspaceBorder"
                Classes="shell-panel"
                IsVisible="False"
                Padding="4"
                BorderThickness="1"
                Background="{DynamicResource ChummerShellSurfaceBrush}"
                BorderBrush="{DynamicResource ChummerShellBorderBrush}">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="4">
            <TextBlock x:Name="BrowseSummaryText"
                       Text="Browse workspace"
                       FontWeight="Bold"
                       TextWrapping="Wrap" />
            <ListBox Grid.Row="1" x:Name="BrowsePresetsList" Height="56">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
            <ListBox Grid.Row="2" x:Name="BrowseFacetsList" Height="96">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
            <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="8">
              <ListBox Grid.Column="0" x:Name="BrowseResultsList" Height="160">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
              </ListBox>
              <TextBox Grid.Column="1"
                       x:Name="BrowseDetailBox"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       IsReadOnly="True" />
            </Grid>
            <ListBox Grid.Row="4" x:Name="BrowseSelectedItemsList" Height="76">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
          </Grid>
        </Border>
        <Border Grid.Row="4"
                x:Name="ContactGraphBorder"
                Classes="shell-panel"
                IsVisible="False"
                Padding="4"
                BorderThickness="1"
                Background="{DynamicResource ChummerShellSurfaceBrush}"
                BorderBrush="{DynamicResource ChummerShellBorderBrush}">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="4">
            <TextBlock x:Name="ContactGraphSummaryText"
                       Text="Contact relationship graph"
                       FontWeight="Bold"
                       TextWrapping="Wrap" />
            <ListBox Grid.Row="1" x:Name="ContactNodeList" Height="112">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
            <TextBox Grid.Row="2"
                     x:Name="ContactFactionStatusBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True" />
            <TextBox Grid.Row="3"
                     x:Name="ContactHeatObligationBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True" />
            <TextBox Grid.Row="4"
                     x:Name="ContactFavorRailBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True" />
          </Grid>
        </Border>
        <Border Grid.Row="5"
                x:Name="NpcPersonaStudioBorder"
                Classes="shell-panel"
                IsVisible="False"
                Padding="4"
                BorderThickness="1"
                Background="{DynamicResource ChummerShellSurfaceBrush}"
                BorderBrush="{DynamicResource ChummerShellBorderBrush}">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="4">
            <TextBlock x:Name="NpcPersonaSummaryText"
                       Text="NPC Persona Studio"
                       FontWeight="Bold"
                       TextWrapping="Wrap" />
            <ListBox Grid.Row="1" x:Name="NpcPersonaList" Height="92">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
            <ListBox Grid.Row="2" x:Name="NpcPolicyList" Height="92">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
            <TextBox Grid.Row="3"
                     x:Name="NpcEvidenceBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True" />
            <TextBox Grid.Row="4"
                     x:Name="NpcApprovalBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True" />
          </Grid>
        </Border>
        <Border Grid.Row="6"
                x:Name="DowntimePlannerBorder"
                Classes="shell-panel"
                IsVisible="False"
                Padding="4"
                BorderThickness="1"
                Background="{DynamicResource ChummerShellSurfaceBrush}"
                BorderBrush="{DynamicResource ChummerShellBorderBrush}">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="4">
            <TextBlock x:Name="DowntimePlannerSummaryText"
                       Text="Downtime planner"
                       FontWeight="Bold"
                       TextWrapping="Wrap" />
            <ListBox Grid.Row="1" x:Name="DowntimePlannerLanesList" Height="92">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
            <TextBox Grid.Row="2"
                     x:Name="DowntimeCalendarBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True" />
            <ListBox Grid.Row="3" x:Name="DowntimeScheduleList" Height="96">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
            </ListBox>
          </Grid>
        </Border>
        <Border Grid.Row="7"
                x:Name="ClassicCharacterSheetBorder"
                Classes="shell-panel subtle"
                IsVisible="False"
                Padding="4">
          <StackPanel Spacing="4">
            <TextBlock x:Name="ClassicCharacterSummaryTitle"
                       Text="Runner Summary"
                       Classes="shell-section-title" />
            <WrapPanel x:Name="ClassicCharacterFactsPanel"
                       Orientation="Horizontal"
                       ItemHeight="44" />
            <WrapPanel x:Name="ClassicAttributeFactsPanel"
                       Orientation="Horizontal"
                       ItemHeight="44" />
          </StackPanel>
        </Border>
        <ListBox Grid.Row="8" x:Name="SectionRowsList" Height="128">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="220,*" ColumnSpacing="8" Margin="0,1">
                <TextBlock Grid.Column="0"
                           Text="{Binding DisplayPath}"
                           Classes="shell-caption"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           Text="{Binding DisplayValue}"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
        </ListBox>
        <Expander Grid.Row="9"
                  x:Name="SectionPayloadExpander"
                  Header="Section Payload"
                  IsExpanded="True"
                  Height="0"
                  MinHeight="0"
                  MaxHeight="0"
                  Opacity="0"
                  IsHitTestVisible="False"
                  ClipToBounds="True">
          <TextBox x:Name="SectionPreviewBox"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   IsReadOnly="True"
                   MinHeight="120" />
        </Expander>
      </Grid>
      </Border>
    </ScrollViewer>

    <Border Grid.Row="2" x:Name="RawXmlImportBorder" Classes="shell-panel subtle" Padding="3" IsVisible="False">
      <Expander Header="Raw XML Import" IsExpanded="False">
        <StackPanel Spacing="2" Margin="0,4,0,0">
          <TextBox x:Name="XmlInputBox"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Height="64"
                   Watermark="Paste raw XML when you need a direct import or diagnostics." />
        </StackPanel>
      </Expander>
    </Border>
  </Grid>
</UserControl>
