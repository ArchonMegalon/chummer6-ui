<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chummer.Avalonia.Controls.NavigatorPaneControl">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="12">
      <Border Classes="shell-card subtle">
        <StackPanel Spacing="8">
          <TextBlock Classes="shell-kicker" Text="Live Workspace" />
          <TextBlock x:Name="OpenWorkspacesHeader" Classes="shell-section-title" Text="Open Characters" />
          <ListBox x:Name="OpenWorkspacesList">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Spacing="2">
                  <TextBlock Classes="shell-section-title" Text="{Binding Name}" />
                  <TextBlock Classes="shell-caption" Text="{Binding Alias, StringFormat=Alias: {0}}" />
                  <TextBlock Classes="shell-kicker" Text="{Binding RulesetId, StringFormat=Ruleset {0}}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <VirtualizingStackPanel />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
          </ListBox>
        </StackPanel>
      </Border>

      <Border Classes="shell-card">
        <StackPanel Spacing="8">
          <TextBlock Classes="shell-kicker" Text="Primary Navigation" />
          <TextBlock x:Name="NavigationTabsHeader" Classes="shell-section-title" Text="Navigation Tabs" />
          <ListBox x:Name="NavigationTabsList">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Spacing="2">
                  <TextBlock Classes="shell-section-title" Text="{Binding Label}" />
                  <TextBlock Classes="shell-caption" Text="{Binding Group, StringFormat=Group: {0}}" />
                  <TextBlock Classes="shell-kicker" Text="{Binding SectionId, StringFormat=Section {0}}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <VirtualizingStackPanel />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
          </ListBox>
        </StackPanel>
      </Border>

      <Border Classes="shell-card">
        <StackPanel Spacing="8">
          <TextBlock Classes="shell-kicker" Text="Section Actions" />
          <TextBlock x:Name="SectionActionsHeader" Classes="shell-section-title" Text="Section Actions" />
          <ListBox x:Name="SectionActionsList">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Spacing="2">
                  <TextBlock Classes="shell-section-title" Text="{Binding Label}" />
                  <TextBlock Classes="shell-caption" Text="{Binding Kind, StringFormat=Action kind: {0}}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <VirtualizingStackPanel />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
          </ListBox>
        </StackPanel>
      </Border>

      <Border Classes="shell-card subtle">
        <StackPanel Spacing="8">
          <TextBlock Classes="shell-kicker" Text="Workflow Surfaces" />
          <TextBlock x:Name="WorkflowSurfacesHeader" Classes="shell-section-title" Text="Workflow Surfaces" />
          <ListBox x:Name="WorkflowSurfacesList">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Spacing="2">
                  <TextBlock Classes="shell-section-title" Text="{Binding Label}" />
                  <TextBlock Classes="shell-caption" Text="{Binding WorkflowId, StringFormat=Workflow: {0}}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <VirtualizingStackPanel />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
          </ListBox>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
