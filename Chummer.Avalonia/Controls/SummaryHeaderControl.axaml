<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chummer.Avalonia.Controls.SummaryHeaderControl">
  <Border x:Name="LoadedRunnerTabStripBorder"
          Classes="shell-card subtle"
          Padding="10,8"
          IsVisible="False">
    <StackPanel Spacing="8">
      <TextBlock x:Name="LoadedRunnerTabStripHeading"
                 Classes="shell-kicker"
                 Text="Runner Tabs" />
      <WrapPanel x:Name="LoadedRunnerTabStripPanel"
                 Orientation="Horizontal" />
    </StackPanel>
  </Border>
</UserControl>
