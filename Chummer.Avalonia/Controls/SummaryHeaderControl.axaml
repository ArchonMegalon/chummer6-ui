<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chummer.Avalonia.Controls.SummaryHeaderControl">
  <Grid Height="0"
        MinHeight="0"
        MaxHeight="0"
        IsVisible="False"
        IsHitTestVisible="False">
    <Border x:Name="RestoreContinuityStatusBorder"
            IsVisible="False"
            Width="0"
            Height="0" />
    <StackPanel x:Name="RestoreContinuityActionPanel"
                IsVisible="False"
                Width="0"
                Height="0" />
  </Grid>
</UserControl>
