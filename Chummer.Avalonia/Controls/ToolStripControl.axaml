<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Chummer.Avalonia.Controls.ToolStripControl">
  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
    <WrapPanel Orientation="Horizontal" ItemHeight="28"
               Grid.Column="0"
               Classes="shell-toolstrip-band"
               VerticalAlignment="Center">
      <Button x:Name="SaveButton" Classes="shell-action" MinWidth="26" Width="26" Height="24" Padding="0" Margin="0,0,3,0" Click="SaveButton_OnClick" />
      <Button x:Name="PrintButton" Classes="shell-action" MinWidth="26" Width="26" Height="24" Padding="0" Margin="0,0,3,0" Click="PrintButton_OnClick" />
      <Button x:Name="CopyButton" Classes="shell-action" MinWidth="26" Width="26" Height="24" Padding="0" Margin="0,0,3,0" Click="CopyButton_OnClick" />
      <Button x:Name="DesktopHomeButton" Classes="shell-action" MinWidth="26" Width="26" Height="24" Padding="0" Margin="0,0,3,0" Click="DesktopHomeButton_OnClick" />
      <Button x:Name="ImportFileButton" Classes="shell-action" MinWidth="26" Width="26" Height="24" Padding="0" Margin="0,0,3,0" Click="ImportFileButton_OnClick" />
      <Button x:Name="CloseWorkspaceButton" Classes="shell-action" MinWidth="26" Width="26" Height="24" Padding="0" Margin="0,0,3,0" Click="CloseWorkspaceButton_OnClick" />
      <Button x:Name="OpenForPrintingButton" IsVisible="False" Classes="shell-action" MinWidth="26" Width="26" Height="24" Padding="0" Margin="0,0,3,0" Click="OpenForPrintingButton_OnClick" />
      <Button x:Name="OpenForExportButton" IsVisible="False" Classes="shell-action" MinWidth="26" Width="26" Height="24" Padding="0" Margin="0,0,3,0" Click="OpenForExportButton_OnClick" />
      <Button x:Name="LoadDemoRunnerButton" IsVisible="False" Classes="shell-action quiet" Content="Demo" MinWidth="48" Margin="0,0,3,0" Click="LoadDemoRunnerButton_OnClick" />
      <Button x:Name="ImportRawButton" IsVisible="False" Classes="shell-action quiet" Content="XML" MinWidth="42" Margin="0,0,3,0" Click="ImportRawButton_OnClick" />
      <Button x:Name="SettingsButton" IsVisible="False" Classes="shell-action quiet" Content="Options" MinWidth="62" Click="SettingsButton_OnClick" />
      <Button x:Name="CampaignWorkspaceButton" IsVisible="False" Content="Campaign" Click="CampaignWorkspaceButton_OnClick" />
      <Button x:Name="UpdateStatusButton" IsVisible="False" Content="Update" Click="UpdateStatusButton_OnClick" />
      <Button x:Name="InstallLinkingButton" IsVisible="False" Content="Link" Click="InstallLinkingButton_OnClick" />
      <Button x:Name="SupportButton" IsVisible="False" Content="Support" Click="SupportButton_OnClick" />
      <Button x:Name="ReportIssueButton" IsVisible="False" Content="Bug" Click="ReportIssueButton_OnClick" />
    </WrapPanel>

    <Border x:Name="StatusTextBorder"
            Grid.Column="1"
            Classes="shell-toolstrip-state"
            Padding="4,0"
            IsHitTestVisible="False">
      <TextBlock x:Name="StatusText"
                 Classes="shell-caption"
                 VerticalAlignment="Center"
                 Text="State: idle"
                 TextTrimming="CharacterEllipsis" />
    </Border>
  </Grid>
</UserControl>
