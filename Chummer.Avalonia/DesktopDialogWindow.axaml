<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Chummer.Avalonia.DesktopDialogWindow"
        Width="760"
        Height="520"
        MinWidth="560"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource ChummerShellSurfaceAltBrush}"
        Title="Dialog">
  <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10" Margin="12">
    <Border Grid.Row="0" BorderThickness="1" BorderBrush="{DynamicResource ChummerShellCardBorderBrush}" Padding="8" Background="{DynamicResource ChummerShellDialogHeaderBrush}">
      <TextBlock Name="DialogTitleText" FontWeight="Bold" Text="Dialog" />
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="10">
        <TextBlock Name="DialogMessageText" TextWrapping="Wrap" />

        <StackPanel Name="DialogFieldsPanel" Spacing="10" />
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2" Name="DialogActionsPanel" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" />
  </Grid>
</Window>
