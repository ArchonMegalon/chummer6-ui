<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Chummer.Avalonia.Controls"
        x:Class="Chummer.Avalonia.MainWindow"
        Width="1360"
        Height="860"
        MinWidth="1000"
        MinHeight="680"
        Title="Chummer Desktop"
        Background="{DynamicResource ChummerShellWindowBackgroundBrush}"
        KeyDown="Window_OnKeyDown">
  <Window.Styles>
    <Style Selector="Button.menu-button.active-menu">
      <Setter Property="Background" Value="{DynamicResource ChummerShellActiveMenuBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellActiveMenuBorderBrush}" />
    </Style>
  </Window.Styles>
  <Grid Margin="8" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="6">
    <Border x:Name="MenuBarRegion" Grid.Row="0" Classes="shell-panel chrome" Padding="4">
      <controls:ShellMenuBarControl x:Name="ShellMenuBarControl" />
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="2.35*,0.95*" ColumnSpacing="6">
      <Border x:Name="ToolStripRegion" Grid.Column="0" Classes="shell-panel chrome" Padding="6">
        <controls:ToolStripControl x:Name="ToolStripControl" />
      </Border>
      <Border x:Name="WorkspaceStripRegion" Grid.Column="1" Classes="shell-panel subtle" Padding="8,6">
        <controls:WorkspaceStripControl x:Name="WorkspaceStripControl" />
      </Border>
    </Grid>

    <Grid x:Name="ContentRegion" Grid.Row="2" ColumnDefinitions="272,*,292" ColumnSpacing="6">
      <Border x:Name="LeftNavigatorRegion" Grid.Column="0" Classes="shell-panel">
        <controls:NavigatorPaneControl x:Name="NavigatorPaneControl" />
      </Border>

      <Grid x:Name="CenterShellRegion" Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="6">
        <Border x:Name="SummaryHeaderRegion" Grid.Row="0" Classes="shell-panel subtle">
          <controls:SummaryHeaderControl x:Name="SummaryHeaderControl" />
        </Border>

        <Border x:Name="SectionRegion" Grid.Row="1" Classes="shell-panel" Padding="0">
          <controls:SectionHostControl x:Name="SectionHostControl" />
        </Border>
      </Grid>

      <Border x:Name="RightShellRegion" Grid.Column="2" Classes="shell-panel">
        <Grid RowDefinitions="2*,*" RowSpacing="6">
          <Border Grid.Row="0" Classes="shell-card">
            <controls:CommandDialogPaneControl x:Name="CommandDialogPaneControl" />
          </Border>
          <Border Grid.Row="1" Classes="shell-card subtle">
            <controls:CoachSidecarControl x:Name="CoachSidecarControl" />
          </Border>
        </Grid>
      </Border>
    </Grid>

    <Border x:Name="StatusStripRegion" Grid.Row="3" Classes="shell-panel chrome" Padding="8,4">
      <controls:StatusStripControl x:Name="StatusStripControl" />
    </Border>
  </Grid>
</Window>
