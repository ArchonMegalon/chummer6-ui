<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Chummer.Avalonia.Controls"
        x:Class="Chummer.Avalonia.MainWindow"
        Width="1220"
        Height="760"
        MinWidth="960"
        MinHeight="560"
        Title="Chummer Desktop"
        Icon="/Assets/chummer.ico"
        Background="{DynamicResource ChummerShellWindowBackgroundBrush}"
        KeyDown="Window_OnKeyDown">
  <Window.Styles>
    <Style Selector="MenuItem.active-menu">
      <Setter Property="Background" Value="{DynamicResource ChummerShellActiveMenuBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellActiveMenuBorderBrush}" />
    </Style>
  </Window.Styles>
  <Grid Margin="0" RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="0">
    <Border x:Name="MenuBarRegion" Grid.Row="0" Classes="shell-panel chrome" Padding="0">
      <controls:ShellMenuBarControl x:Name="ShellMenuBarControl" />
    </Border>

    <Border x:Name="ToolStripRegion" Grid.Row="1" Classes="shell-panel chrome" Padding="1">
      <controls:ToolStripControl x:Name="ToolStripControl" />
    </Border>

    <Border x:Name="SummaryHeaderRegion" Grid.Row="2" Classes="shell-panel chrome" Padding="0">
      <controls:SummaryHeaderControl x:Name="SummaryHeaderControl" />
    </Border>

    <Grid x:Name="ContentRegion" Grid.Row="3" ColumnDefinitions="184,*,0" ColumnSpacing="2" Margin="1,1,1,0">
      <Border x:Name="LeftNavigatorRegion" Grid.Column="0" Classes="shell-panel">
        <controls:NavigatorPaneControl x:Name="NavigatorPaneControl" />
      </Border>

      <Grid x:Name="CenterShellRegion" Grid.Column="1">
        <Border x:Name="SectionRegion" Classes="shell-panel" Padding="0">
          <controls:SectionHostControl x:Name="SectionHostControl" />
        </Border>
      </Grid>

      <Border x:Name="RightShellRegion"
              Grid.Column="2"
              Classes="shell-panel"
              Width="0"
              MinWidth="0"
              MaxWidth="0"
              Opacity="0"
              IsHitTestVisible="False"
              ClipToBounds="True">
        <Grid RowDefinitions="2*,*" RowSpacing="4">
          <Border Grid.Row="0" Classes="shell-card">
            <controls:CommandDialogPaneControl x:Name="CommandDialogPaneControl" />
          </Border>
          <Border Grid.Row="1" Classes="shell-card subtle">
            <controls:CoachSidecarControl x:Name="CoachSidecarControl" />
          </Border>
        </Grid>
      </Border>
    </Grid>

    <Border x:Name="StatusStripRegion" Grid.Row="4" Classes="shell-panel chrome" Padding="4,1">
      <controls:StatusStripControl x:Name="StatusStripControl" />
    </Border>
  </Grid>
</Window>
