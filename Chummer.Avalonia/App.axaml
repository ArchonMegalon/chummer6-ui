<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:Avalonia.Controls.Primitives;assembly=Avalonia.Controls"
             x:Class="Chummer.Avalonia.App"
             RequestedThemeVariant="Default">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="ChummerShellWindowBackgroundBrush" Color="#F3F6FB" />
          <SolidColorBrush x:Key="ChummerShellForegroundBrush" Color="#0F172A" />
          <SolidColorBrush x:Key="ChummerShellMutedForegroundBrush" Color="#475569" />
          <SolidColorBrush x:Key="ChummerShellChromeBrush" Color="#E2E8F0" />
          <SolidColorBrush x:Key="ChummerShellChromeSubtleBrush" Color="#EEF2FF" />
          <SolidColorBrush x:Key="ChummerShellChromeAccentBrush" Color="#E0E7FF" />
          <SolidColorBrush x:Key="ChummerShellPanelOverlayBrush" Color="#F8FAFC" />
          <SolidColorBrush x:Key="ChummerShellPanelMutedBrush" Color="#F1F5F9" />
          <SolidColorBrush x:Key="ChummerShellBorderStrongBrush" Color="#94A3B8" />
          <SolidColorBrush x:Key="ChummerShellBorderBrush" Color="#CBD5E1" />
          <SolidColorBrush x:Key="ChummerShellCardBorderBrush" Color="#64748B" />
          <SolidColorBrush x:Key="ChummerShellSurfaceBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="ChummerShellSurfaceAltBrush" Color="#F8FAFC" />
          <SolidColorBrush x:Key="ChummerShellActiveMenuBackgroundBrush" Color="#D5E5D8" />
          <SolidColorBrush x:Key="ChummerShellActiveMenuBorderBrush" Color="#1C4A2D" />
          <SolidColorBrush x:Key="ChummerShellDialogHeaderBrush" Color="#E2E8F0" />
          <SolidColorBrush x:Key="ChummerShellCodeSurfaceBrush" Color="#F8FAFC" />
          <SolidColorBrush x:Key="ChummerShellInputBackgroundBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="ChummerShellInputForegroundBrush" Color="#0F172A" />
          <SolidColorBrush x:Key="ChummerShellSelectionBrush" Color="#BFDBFE" />
          <SolidColorBrush x:Key="ChummerShellSelectionForegroundBrush" Color="#0F172A" />
          <SolidColorBrush x:Key="ChummerShellAccentButtonBrush" Color="#1C4A2D" />
          <SolidColorBrush x:Key="ChummerShellAccentButtonForegroundBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="ChummerShellInfoBrush" Color="#2563EB" />
          <SolidColorBrush x:Key="ChummerShellWarningBrush" Color="#B45309" />
          <SolidColorBrush x:Key="ChummerShellDangerBrush" Color="#DC2626" />
          <SolidColorBrush x:Key="ChummerShellFocusRingBrush" Color="#1C4A2D" />
          <SolidColorBrush x:Key="ChummerShellSuccessBrush" Color="#047857" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="ChummerShellWindowBackgroundBrush" Color="#050B16" />
          <SolidColorBrush x:Key="ChummerShellForegroundBrush" Color="#E5E7EB" />
          <SolidColorBrush x:Key="ChummerShellMutedForegroundBrush" Color="#CBD5E1" />
          <SolidColorBrush x:Key="ChummerShellChromeBrush" Color="#0F172A" />
          <SolidColorBrush x:Key="ChummerShellChromeSubtleBrush" Color="#111827" />
          <SolidColorBrush x:Key="ChummerShellChromeAccentBrush" Color="#172554" />
          <SolidColorBrush x:Key="ChummerShellPanelOverlayBrush" Color="#0F172A" />
          <SolidColorBrush x:Key="ChummerShellPanelMutedBrush" Color="#111827" />
          <SolidColorBrush x:Key="ChummerShellBorderStrongBrush" Color="#475569" />
          <SolidColorBrush x:Key="ChummerShellBorderBrush" Color="#334155" />
          <SolidColorBrush x:Key="ChummerShellCardBorderBrush" Color="#64748B" />
          <SolidColorBrush x:Key="ChummerShellSurfaceBrush" Color="#111827" />
          <SolidColorBrush x:Key="ChummerShellSurfaceAltBrush" Color="#020617" />
          <SolidColorBrush x:Key="ChummerShellActiveMenuBackgroundBrush" Color="#1C4A2D" />
          <SolidColorBrush x:Key="ChummerShellActiveMenuBorderBrush" Color="#90C39A" />
          <SolidColorBrush x:Key="ChummerShellDialogHeaderBrush" Color="#111827" />
          <SolidColorBrush x:Key="ChummerShellCodeSurfaceBrush" Color="#0F172A" />
          <SolidColorBrush x:Key="ChummerShellInputBackgroundBrush" Color="#162031" />
          <SolidColorBrush x:Key="ChummerShellInputForegroundBrush" Color="#F8FAFC" />
          <SolidColorBrush x:Key="ChummerShellSelectionBrush" Color="#1D4ED8" />
          <SolidColorBrush x:Key="ChummerShellSelectionForegroundBrush" Color="#F8FAFC" />
          <SolidColorBrush x:Key="ChummerShellAccentButtonBrush" Color="#1C4A2D" />
          <SolidColorBrush x:Key="ChummerShellAccentButtonForegroundBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="ChummerShellInfoBrush" Color="#60A5FA" />
          <SolidColorBrush x:Key="ChummerShellWarningBrush" Color="#F59E0B" />
          <SolidColorBrush x:Key="ChummerShellDangerBrush" Color="#F87171" />
          <SolidColorBrush x:Key="ChummerShellFocusRingBrush" Color="#90C39A" />
          <SolidColorBrush x:Key="ChummerShellSuccessBrush" Color="#34D399" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>
  <Application.Styles>
    <FluentTheme DensityStyle="Compact" />
    <Style Selector="Window">
      <Setter Property="Background" Value="{DynamicResource ChummerShellWindowBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChummerShellForegroundBrush}" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="UserControl">
      <Setter Property="Foreground" Value="{DynamicResource ChummerShellForegroundBrush}" />
    </Style>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource ChummerShellForegroundBrush}" />
    </Style>
    <Style Selector="TextBlock.shell-kicker">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource ChummerShellMutedForegroundBrush}" />
    </Style>
    <Style Selector="TextBlock.shell-title">
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.shell-subtitle">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource ChummerShellMutedForegroundBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.shell-section-title">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.shell-caption">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource ChummerShellMutedForegroundBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.shell-tree-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>
    <Style Selector="TextBlock.shell-tab-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>
    <Style Selector="StackPanel.shell-toolstrip-band">
      <Setter Property="Spacing" Value="4" />
    </Style>
    <Style Selector="Border.shell-toolstrip-state">
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellBorderStrongBrush}" />
    </Style>
    <Style Selector="TextBlock.shell-metric-value">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="Border.shell-panel">
      <Setter Property="Background" Value="{DynamicResource ChummerShellSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="3" />
    </Style>
    <Style Selector="Border.shell-panel.chrome">
      <Setter Property="Background" Value="{DynamicResource ChummerShellChromeBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellBorderStrongBrush}" />
    </Style>
    <Style Selector="Border.shell-panel.subtle">
      <Setter Property="Background" Value="{DynamicResource ChummerShellChromeSubtleBrush}" />
    </Style>
    <Style Selector="Border.shell-panel.accent">
      <Setter Property="Background" Value="{DynamicResource ChummerShellChromeAccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellActiveMenuBorderBrush}" />
    </Style>
    <Style Selector="Border.shell-card">
      <Setter Property="Background" Value="{DynamicResource ChummerShellPanelOverlayBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Padding" Value="3" />
    </Style>
    <Style Selector="Border.shell-card.subtle">
      <Setter Property="Background" Value="{DynamicResource ChummerShellPanelMutedBrush}" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource ChummerShellInputBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChummerShellInputForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellBorderBrush}" />
      <Setter Property="CaretBrush" Value="{DynamicResource ChummerShellInputForegroundBrush}" />
      <Setter Property="Padding" Value="4,3" />
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellFocusRingBrush}" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Background" Value="{DynamicResource ChummerShellPanelOverlayBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChummerShellForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="5,1" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="CornerRadius" Value="2" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellActiveMenuBorderBrush}" />
      <Setter Property="Background" Value="{DynamicResource ChummerShellChromeSubtleBrush}" />
    </Style>
    <Style Selector="Button:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellFocusRingBrush}" />
    </Style>
    <Style Selector="Button.menu-button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="MinHeight" Value="24" />
    </Style>
    <Style Selector="Button.menu-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChummerShellChromeSubtleBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellBorderBrush}" />
    </Style>
    <Style Selector="Button.shell-action.primary">
      <Setter Property="Background" Value="{DynamicResource ChummerShellAccentButtonBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChummerShellAccentButtonForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellAccentButtonBrush}" />
    </Style>
    <Style Selector="Button.shell-action.primary:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChummerShellActiveMenuBorderBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellActiveMenuBorderBrush}" />
    </Style>
    <Style Selector="Button.shell-action.quiet">
      <Setter Property="Background" Value="{DynamicResource ChummerShellChromeSubtleBrush}" />
    </Style>
    <Style Selector="Menu.classic-menu">
      <Setter Property="Background" Value="{DynamicResource ChummerShellChromeBrush}" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="MenuItem">
      <Setter Property="Padding" Value="6,2" />
      <Setter Property="MinHeight" Value="22" />
    </Style>
    <Style Selector="MenuItem.primary-menu-command">
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="primitives|TabStrip.classic-tabs">
      <Setter Property="MinHeight" Value="24" />
    </Style>
    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="3,1" />
      <Setter Property="Margin" Value="0,0,0,1" />
      <Setter Property="Foreground" Value="{DynamicResource ChummerShellForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Background" Value="{DynamicResource ChummerShellPanelOverlayBrush}" />
    </Style>
    <Style Selector="ListBoxItem:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellActiveMenuBorderBrush}" />
      <Setter Property="Background" Value="{DynamicResource ChummerShellChromeSubtleBrush}" />
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource ChummerShellSelectionBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChummerShellSelectionForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChummerShellActiveMenuBorderBrush}" />
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource ChummerShellForegroundBrush}" />
    </Style>
  </Application.Styles>
</Application>
