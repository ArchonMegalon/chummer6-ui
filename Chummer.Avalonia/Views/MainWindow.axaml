<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AvaloniaProject.Views.MainWindow"
        Title="Build Lab Dashboard"
        Width="600" Height="400"
        Background="{DynamicResource ChummerShellSurfaceAltBrush}">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="Build Lab Dashboard" FontSize="24" FontWeight="Bold" />
        
        <TextBlock Text="Build Parameters:" />
        <TextBox x:Name="ParametersTextBox" Text="Alpha_Release_v1.0" Background="{DynamicResource ChummerShellCodeSurfaceBrush}" BorderBrush="{DynamicResource ChummerShellBorderBrush}" />
        
        <Button x:Name="SimulateBuildButton" Content="Simulate Build" Click="OnSimulateBuildClicked" 
                Background="{DynamicResource ChummerShellAccentButtonBrush}" Foreground="{DynamicResource ChummerShellAccentButtonForegroundBrush}" Padding="15,8" HorizontalAlignment="Left" />
        
        <TextBlock Text="Build Output:" FontWeight="SemiBold" Margin="0,10,0,0" />
        <Border Background="{DynamicResource ChummerShellCodeSurfaceBrush}" BorderBrush="{DynamicResource ChummerShellBorderBrush}" BorderThickness="1" Padding="10" CornerRadius="3">
            <TextBlock x:Name="ResultTextBlock" Text="Ready." TextWrapping="Wrap" FontFamily="Consolas" Foreground="{DynamicResource ChummerShellSuccessBrush}" />
        </Border>
    </StackPanel>
</Window>
