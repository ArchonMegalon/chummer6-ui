<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AvaloniaProject.Views.MainWindow"
        Title="Build Lab Dashboard"
        Width="600" Height="400"
        Background="#1E1E1E" Foreground="#E0E0E0">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="Build Lab Dashboard" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" />
        
        <TextBlock Text="Build Parameters:" />
        <TextBox x:Name="ParametersTextBox" Text="Alpha_Release_v1.0" Background="#2D2D30" Foreground="#FFFFFF" BorderBrush="#3F3F46" />
        
        <Button x:Name="SimulateBuildButton" Content="Simulate Build" Click="OnSimulateBuildClicked" 
                Background="#007ACC" Foreground="White" Padding="15,8" HorizontalAlignment="Left" />
        
        <TextBlock Text="Build Output:" FontWeight="SemiBold" Margin="0,10,0,0" />
        <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" Padding="10" CornerRadius="3">
            <TextBlock x:Name="ResultTextBlock" Text="Ready." TextWrapping="Wrap" FontFamily="Consolas" Foreground="#4EC9B0" />
        </Border>
    </StackPanel>
</Window>
