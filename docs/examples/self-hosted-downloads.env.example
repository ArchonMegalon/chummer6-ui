# Recommended self-hosted downloads publication topology:
# self-hosted runner writes directly into mounted portal downloads storage.
CHUMMER_DESKTOP_RELEASE_CHANNEL=preview
CHUMMER_PORTAL_DOWNLOADS_DEPLOY_ENABLED=true
CHUMMER_PORTAL_DOWNLOADS_DEPLOY_DIR=/srv/chummer/portal-downloads
CHUMMER_PORTAL_DOWNLOADS_VERIFY_URL=https://chummer.example.com/downloads/releases.json
CHUMMER_PORTAL_DOWNLOADS_REQUIRE_PUBLISHED_VERSION=true
CHUMMER_PORTAL_DOWNLOADS_VERIFY_LINKS=true

# Alternate object-storage topology:
# uncomment and fill these when the runner cannot write to portal storage directly.
# CHUMMER_PORTAL_DOWNLOADS_S3_URI=s3://chummer-downloads/releases
# CHUMMER_PORTAL_DOWNLOADS_S3_LATEST_URI=s3://chummer-downloads/latest
# CHUMMER_PORTAL_DOWNLOADS_S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
# CHUMMER_PORTAL_DOWNLOADS_S3_REGION=us-east-1
# CHUMMER_PORTAL_DOWNLOADS_AWS_ACCESS_KEY_ID=replace-me
# CHUMMER_PORTAL_DOWNLOADS_AWS_SECRET_ACCESS_KEY=replace-me
# CHUMMER_PORTAL_DOWNLOADS_AWS_SESSION_TOKEN=

# Live chummer.run upload topology:
# uncomment these when the release lane should push the newest successful bundle
# directly to the live chummer.run shelf after Desktop Downloads Matrix succeeds.
# CHUMMER_RELEASE_UPLOAD_URL=https://chummer.run/api/internal/releases/bundles
# CHUMMER_RELEASE_UPLOAD_TOKEN=replace-me

# Public/stable desktop release signing:
# uncomment and fill these when CHUMMER_DESKTOP_RELEASE_CHANNEL is release_candidate or public_stable.
# CHUMMER_WINDOWS_SIGN_PFX_BASE64=replace-me
# CHUMMER_WINDOWS_SIGN_PFX_PASSWORD=replace-me
# CHUMMER_WINDOWS_TIMESTAMP_URL=http://timestamp.digicert.com
# CHUMMER_MAC_CERTIFICATE_P12_BASE64=replace-me
# CHUMMER_MAC_CERTIFICATE_PASSWORD=replace-me
# CHUMMER_MAC_KEYCHAIN_PASSWORD=replace-me
# CHUMMER_MAC_APPLE_ID=replace-me
# CHUMMER_MAC_APPLE_APP_PASSWORD=replace-me
# CHUMMER_MAC_TEAM_ID=TEAMID
# CHUMMER_MAC_APP_SIGN_IDENTITY=Developer ID Application: Example Corp (TEAMID)
# CHUMMER_MAC_NOTARY_PROFILE=chummer-notary
