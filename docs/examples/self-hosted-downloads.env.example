# Recommended self-hosted downloads publication topology:
# self-hosted runner writes directly into mounted portal downloads storage.
CHUMMER_PORTAL_DOWNLOADS_DEPLOY_ENABLED=true
CHUMMER_PORTAL_DOWNLOADS_DEPLOY_DIR=/srv/chummer/portal-downloads
CHUMMER_PORTAL_DOWNLOADS_VERIFY_URL=https://chummer.example.com/downloads/releases.json
CHUMMER_PORTAL_DOWNLOADS_REQUIRE_PUBLISHED_VERSION=true
CHUMMER_PORTAL_DOWNLOADS_VERIFY_LINKS=true

# Alternate object-storage topology:
# uncomment and fill these when the runner cannot write to portal storage directly.
# CHUMMER_PORTAL_DOWNLOADS_S3_URI=s3://chummer-downloads/releases
# CHUMMER_PORTAL_DOWNLOADS_S3_LATEST_URI=s3://chummer-downloads/latest
# CHUMMER_PORTAL_DOWNLOADS_S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
# CHUMMER_PORTAL_DOWNLOADS_S3_REGION=us-east-1
# CHUMMER_PORTAL_DOWNLOADS_AWS_ACCESS_KEY_ID=replace-me
# CHUMMER_PORTAL_DOWNLOADS_AWS_SECRET_ACCESS_KEY=replace-me
# CHUMMER_PORTAL_DOWNLOADS_AWS_SESSION_TOKEN=
